               function ObtenerDoctores() {
            $("#tab-doctor").LoadingOverlay("show");

            fetch(`/Doctor/Lista`, {
                method: "GET",
                headers: { 'Content-Type': 'application/json;charset=utf-8' }
            }).then(response => {
                return response.ok ? response.json() : Promise.reject(response);
            }).then(responseJson => {
                if (responseJson.data.length > 0) {
                    // NUEVA FILOSOFÍA: Filtramos buscando si la especialidad seleccionada
                    // está dentro de la lista 'especialidadesDoc' de cada doctor
                    Doctores = responseJson.data.filter(doctor =>
                        doctor.especialidadesDoc &&
                        doctor.especialidadesDoc.some(e => e.idEspecialidad == IdEspecialidadSeleccionada)
                    );

                    // Si hay doctores, los pintamos con la función visual que creamos antes
                    if (Doctores.length > 0) {
                        BuscarDoctor("");
                    } else {
                        // Si no hay nadie para esa especialidad, limpiamos el contenedor
                        $("#contenedor-doctores").html(
                            '<div class="col-12 text-center mt-4">' +
                            '<div class="alert alert-info">No hay doctores disponibles para esta especialidad actualmente.</div>' +
                            '</div>'
                        );
                    }
                } else {
                    Doctores = [];
                    $("#contenedor-doctores").html('<div class="col-12 text-center mt-4">No se encontraron doctores en el sistema.</div>');
                }

                $("#tab-doctor").LoadingOverlay("hide");

            }).catch((error) => {
                $("#tab-doctor").LoadingOverlay("hide");
                console.error("Error al obtener doctores:", error);
                Swal.fire({
                    title: "Error!",
                    text: "No se pudo conectar con el servidor para obtener la lista de doctores.",
                    icon: "error"
                });
            });
        }
                       function ObtenerDoctoreHorarioDetalle() {
            $("#txtFechaCita").datepicker("destroy");
            $("#tab-horario").LoadingOverlay("show");
            $("#contenedor-am").html("");
            $("#contenedor-pm").html("");

            fetch(`/Citas/ListaDoctorHorarioDetalle?Id=${IdDoctorSeleccionado}`, {
                method: "GET",
                headers: { 'Content-Type': 'application/json;charset=utf-8' }
            }).then(response => {
                return response.ok ? response.json() : Promise.reject(response);
            }).then(responseJson => {

                if (responseJson.data.length > 0) {
                    const arraySoloFechas = responseJson.data.map(item => item.fecha);
                    DoctorHorario = responseJson.data;

                    $("#txtFechaCita").datepicker({
                        dateFormat: "dd/mm/yy",
                        defaultDate: "",
                        minDate: 0,
                        beforeShowDay: function (date) {
                            var formattedDate = $.datepicker.formatDate("dd/mm/yy", date);
                            var esFechaPermitida = ($.inArray(formattedDate, arraySoloFechas) !== -1);
                            return [esFechaPermitida, ""];
                        },
                        onSelect: function () {
                            $("#btnSiguiente").prop("disabled", true);
                            $("#contenedor-am").html("");
                            $("#contenedor-pm").html("");

                            const selectedDate = $(this).val();

                            const Fecha = DoctorHorario.find(element => element.fecha.trim() == selectedDate.trim());

                            if (Fecha && Fecha.horarioDTO) {
                                const HorarioAM = Fecha.horarioDTO.filter(element => element.turno == "AM");
                                const HorarioPM = Fecha.horarioDTO.filter(element => element.turno == "PM");

                                HorarioAM.forEach(function (item) {
                                    $("#contenedor-am").append(
                                        `<div class="col mb-4">

                                            <div class="text-center card-hora"
                                                 style="cursor: pointer;border-radius: 0.375rem;border: 1px solid #ccc !important;"
                                                 data-id="${item.idDoctorHorarioDetalle}"
                                                 data-text="${item.turnoHora}"
                                                 ondblclick="ejecutarSiguienteDobleClick()">

                                                <h6 class="card-title mt-2">${item.turnoHora}</h6>
                                            </div>
                                         </div>`
                                    );
                                });

                                HorarioPM.forEach(function (item) {
                                    $("#contenedor-pm").append(
                                        `<div class="col mb-4">

                                            <div class="text-center card-hora"
                                                 style="cursor: pointer;border-radius: 0.375rem;border: 1px solid #ccc !important;"
                                                 data-id="${item.idDoctorHorarioDetalle}"
                                                 data-text="${item.turnoHora}"
                                                 ondblclick="ejecutarSiguienteDobleClick()">

                                                <h6 class="card-title mt-2">${item.turnoHora}</h6>
                                            </div>
                                         </div>`
                                    );
                                });
                            } else {
                                Swal.fire({
                                    text: "No se encontró información detallada para la fecha seleccionada.",
                                    icon: "info"
                                });
                            }
                        }
                    });
                } else {
                    Swal.fire({
                        text: "No hay horarios disponibles.",
                        icon: "warning"
                    });
                }
                $("#tab-horario").LoadingOverlay("hide");
            }).catch((error) => {
                $("#tab-horario").LoadingOverlay("hide");
                Swal.fire({
                    title: "Error!",
                    text: "No se pudieron cargar los horarios.",
                    icon: "warning"
                });
            });
        }
        function enviarCita(objeto) {
            fetch(`/Citas/Guardar`, {
                method: "POST",
                headers: { 'Content-Type': 'application/json;charset=utf-8' },
                body: JSON.stringify(objeto)
            }).then(response => {
                return response.ok ? response.json() : Promise.reject(response);
            }).then(responseJson => {

                if (responseJson.data === "") {
                    Swal.fire({
                        title: "Felicidades!",
                        text: "Su cita fue registrada!",
                        icon: "success"
                    }).then(function () {
                    //    window.location.href = (ES_ADMIN ? '/Gestion/Index' : '/Citas/Index');
                                const urlInicio = document.getElementById('hdnUrlInicio').value;
        window.location.href = urlInicio;
                    });
                    $(`#${modal}`).modal('hide');
                } else {
                    Swal.fire({
                        title: "Error!",
                        text: responseJson.data,
                        icon: "warning"
                    });
                }
            }).catch((error) => {
                console.log(error);
                Swal.fire({
                    title: "Error!",
                    text: "No se pudo registrar.",
                    icon: "warning"
                });
            });
        }


        $("#btnAgendar").on("click", function () {

            if ($("#txtFechaCita").val() === "" || IdHoraSeleccionado === 0) {
                Swal.fire({
                    title: "Error!",
                    text: "Falta completar datos.",
                    icon: "warning"
                });
                return;
            }

            // Como admin: si no viene paciente, no llamamos al backend
            if (ES_ADMIN && (!ID_USUARIO_PACIENTE || ID_USUARIO_PACIENTE <= 0)) {
                Swal.fire({
                    title: "Atención",
                    text: "Como administrador debe abrir 'Nueva Cita' desde el botón 'Nueva cita' de un paciente (para que se pase su Id).",
                    icon: "info"
                });
                return;
            }

            const razon = $("#txtRazonCitaUsr").val() || "";
            const fileInput = $("#fileDocumentoCitaUsr")[0];

            const construirYEnviar = function (fileBase64, contentType) {
                // Si hay recorte de cámara tiene prioridad como documento
                if (altaImagenBlob && !fileBase64) {
                    const reader = new FileReader();
                    reader.readAsDataURL(altaImagenBlob);
                    reader.onload = function(e) {
                        construirYEnviar(e.target.result.split(',')[1], altaImagenBlob.type || "image/jpeg");
                    };
                    return;
                }

                const tipoCita = document.querySelector('input[name="tipoDeCita"]:checked')?.value || "P";

                let objeto = {
                    DoctorHorarioDetalle: {
                        IdDoctorHorarioDetalle: IdHoraSeleccionado
                    },
                    EstadoCita: {
                        IdEstadoCita: 1     // Pendiente
                    },
                    FechaCita: moment($("#txtFechaCita").val(), "DD/MM/YYYY").format('DD/MM/YYYY'),
                    OrigenCita: ES_ADMIN ? "ADMIN" : "WEB",
                    RazonCitaUsr: razon,
                    DocumentoCitaUsr: fileBase64,
                    ContentType: contentType,
                    TipoDeCita: tipoCita,
                    DiagnosticoIA: altaDiagnosticoIA || null
                };

                if (ES_ADMIN && ID_USUARIO_PACIENTE > 0) {
                    objeto.Usuario = {
                        IdUsuario: ID_USUARIO_PACIENTE
                    };
                }

                enviarCita(objeto);
            };

            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const reader = new FileReader();

                reader.onload = function (e) {
                    const result = e.target.result; // data:...;base64,XXXX
                    const base64Data = result.split(',')[1];
                    construirYEnviar(base64Data, file.type);
                };

                reader.onerror = function () {
                    Swal.fire({
                        title: "Error!",
                        text: "No se pudo leer el archivo adjunto.",
                        icon: "warning"
                    });
                };

                reader.readAsDataURL(file);
            } else {
                construirYEnviar(null, null);
            }
        });
                function ejecutarSiguienteDobleClick() {
            // Primero nos aseguramos de que el botón Siguiente no esté deshabilitado
            if (!$("#btnSiguiente").prop("disabled")) {
                $("#btnSiguiente").click();
            }
        }

        // ── Lógica IA AltaCita ─────────────────────────────────────────
        document.addEventListener("DOMContentLoaded", function () {

            // Abrir cámara
            // ── Pantalla completa cámara — idéntico a CitasAsignadas ──
            function altaFsAbrir() {
                // Móvil: bajar z-index del modal para que el fullscreen quede encima
                const _modal = document.getElementById("mdData");
                if (_modal) _modal.style.zIndex = "0";
                document.querySelectorAll(".modal-backdrop").forEach(b => b.style.zIndex = "0");

                document.getElementById("altaFullscreen").classList.add("activo");
                document.body.style.overflow = "hidden";
                document.getElementById("altaFsStreamDiv").style.display = "flex";
                document.getElementById("altaFsCropperDiv").style.display = "none";
                document.getElementById("altaFsControles").style.display = "none";
                document.getElementById("altaFsResultado").classList.remove("visible");
                document.getElementById("altaFsBtnVerResultados").classList.add("d-none");
                altaFsAbrirStream();
            }
            function altaFsCerrar() {
                altaFsCerrarStream();
                if (altaCropper) { altaCropper.destroy(); altaCropper = null; }
                document.getElementById("altaFullscreen").classList.remove("activo");
                document.body.style.overflow = "";
                // Restaurar z-index del modal
                const _modal = document.getElementById("mdData");
                if (_modal) _modal.style.zIndex = "";
                document.querySelectorAll(".modal-backdrop").forEach(b => b.style.zIndex = "");
            }
            function altaFsAbrirStream() {
                altaFsCerrarStream();
                navigator.mediaDevices.getUserMedia({
                    video: { facingMode: altaFacingMode, width: { ideal: 1280 }, height: { ideal: 720 } }
                }).then(function(s) {
                    altaStreamCamara = s;
                    document.getElementById("altaFsVideo").srcObject = s;
                }).catch(function(e) {
                    Swal.fire("Error", "No se pudo acceder a la cámara: " + e.message, "error");
                });
            }
            function altaFsCerrarStream() {
                if (altaStreamCamara) { altaStreamCamara.getTracks().forEach(t => t.stop()); altaStreamCamara = null; }
            }

            document.getElementById("altaBtnAbrirCamara").addEventListener("click", altaFsAbrir);
            document.getElementById("altaFsBtnVolver").addEventListener("click", altaFsCerrar);
            document.getElementById("altaFsBtnVoltear").addEventListener("click", function() {
                altaFacingMode = altaFacingMode === "environment" ? "user" : "environment";
                altaFsAbrirStream();
            });
            document.getElementById("altaFsBtnCapturar").addEventListener("click", function() {
                const video = document.getElementById("altaFsVideo");
                const canvas = document.createElement("canvas");
                canvas.width = video.videoWidth; canvas.height = video.videoHeight;
                canvas.getContext("2d").drawImage(video, 0, 0);
                altaFsCerrarStream();
                document.getElementById("altaFsStreamDiv").style.display = "none";
                const img = document.getElementById("altaFsImgCropper");
                img.src = canvas.toDataURL("image/jpeg", 0.92);
                document.getElementById("altaFsCropperDiv").style.display = "block";
                document.getElementById("altaFsControles").style.display = "block";
                if (altaCropper) { altaCropper.destroy(); altaCropper = null; }
                altaCropper = new Cropper(img, {
                    aspectRatio: NaN, viewMode: 1, autoCropArea: 0.5,
                    responsive: true, movable: true, zoomable: true,
                    cropBoxMovable: true, cropBoxResizable: true, dragMode: "crop"
                });
                document.getElementById("altaFsSliderZoom").value = 0.1;
            });
            document.getElementById("altaFsSliderZoom").addEventListener("input", function() {
                if (altaCropper) altaCropper.zoomTo(parseFloat(this.value));
            });
            document.getElementById("altaFsBtnReset").addEventListener("click", function() {
                if (altaCropper) { altaCropper.reset(); document.getElementById("altaFsSliderZoom").value = 0.1; }
            });
            document.getElementById("altaFsBtnModeMover").addEventListener("click", function() {
                if (!altaCropper) return;
                altaCropper.setDragMode("move");
                this.classList.add("active");
                document.getElementById("altaFsBtnModeRecortar").classList.remove("active");
            });
            document.getElementById("altaFsBtnModeRecortar").addEventListener("click", function() {
                if (!altaCropper) return;
                altaCropper.setDragMode("crop");
                this.classList.add("active");
                document.getElementById("altaFsBtnModeMover").classList.remove("active");
            });
            document.getElementById("altaFsBtnAnalizar").addEventListener("click", function() {
                if (!altaCropper) { Swal.fire("Aviso", "Primero capture una foto.", "warning"); return; }
                const canvas = altaCropper.getCroppedCanvas({ maxWidth: 1600, maxHeight: 1600 });
                const mx = Math.round(canvas.width * 0.10), my = Math.round(canvas.height * 0.10);
                const full = document.createElement("canvas");
                full.width = canvas.width + mx * 2; full.height = canvas.height + my * 2;
                full.getContext("2d").drawImage(canvas, mx, my);
                const btn = this;
                btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Analizando...';
                full.toBlob(function(blob) {
                    altaImagenBlob = blob;
                    // Minipreview en el tab
                    document.getElementById("altaCamaraMiniImg").src = URL.createObjectURL(blob);
                    document.getElementById("altaCamaraMiniPreview").classList.remove("d-none");
                    altaAnalizarBlob(blob, btn);
                }, "image/jpeg", 0.92);
            });
            document.getElementById("altaFsBtnVerResultados").addEventListener("click", function() {
                altaFsCerrar();
                setTimeout(function() {
                    document.getElementById("altaResultadoIA").classList.remove("d-none");
                    document.getElementById("altaResultadoIA").scrollIntoView({ behavior: "smooth" });
                }, 350);
            });

            // Analizar fichero subido — sin cambios
            document.getElementById("altaBtnAnalizarFichero").addEventListener("click", function () {
                const file = document.getElementById("fileDocumentoCitaUsr").files[0];
                if (!file) { Swal.fire("Aviso", "Primero seleccione un fichero de imagen.", "warning"); return; }
                if (!file.type.startsWith("image/")) { Swal.fire("Aviso", "Solo se pueden analizar imágenes con IA.", "warning"); return; }
                altaAnalizarBlob(file, null);
            });

            function altaAnalizarBlob(blob, btn) {
                Swal.fire({ title: "Analizando con IA...", allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                const servicio = document.getElementById("altaServicioIA").value || "dental";
                const razon    = document.getElementById("txtRazonCitaUsr")?.value || "";
                const contexto = razon
                    ? `El paciente describe: "${razon}". Analiza la imagen teniendo en cuenta este contexto.`
                    : "Analiza esta imagen clínica y describe los hallazgos observables.";
                const form = new FormData();
                form.append("idCita",   0);
                form.append("imagen",   blob, "imagen.jpg");
                form.append("servicio", servicio);
                form.append("contexto", contexto);
                fetch("/Citas/AnalizarImagenIA", { method: "POST", body: form })
                .then(r => r.json())
                .then(res => {
                    Swal.close();
                    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-microscope me-1"></i>Analizar recorte con IA'; }
                    if (res.ok) {
                        altaDiagnosticoIA = res.diagnostico;
                        document.getElementById("altaTextoIA").innerText = res.diagnostico;
                        document.getElementById("altaResultadoIA").classList.remove("d-none");
                        // Mostrar botón "Ver resultados y volver" si estamos en fullscreen
                        if (document.getElementById("altaFullscreen").classList.contains("activo")) {
                            document.getElementById("altaFsResultado").innerText = res.diagnostico;
                            document.getElementById("altaFsResultado").classList.add("visible");
                            document.getElementById("altaFsBtnVerResultados").classList.remove("d-none");
                        }
                    } else {
                        Swal.fire("Error IA", res.msg || "Error desconocido", "error");
                    }
                })
                .catch(() => {
                    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-microscope me-1"></i>Analizar recorte con IA'; }
                    Swal.fire("Error", "Fallo de comunicación con el servidor.", "error");
                });
            }

            // Cerrar cámara al cerrar modal
            document.getElementById("mdData").addEventListener("hidden.bs.modal", function () {
                altaFsCerrar();
                if (altaCropper) { altaCropper.destroy(); altaCropper = null; }
                altaImagenBlob    = null;
                altaDiagnosticoIA = "";
                document.getElementById("altaResultadoIA").classList.add("d-none");
                document.getElementById("altaCamaraMiniPreview").classList.add("d-none");
            });
        });
    </script>
}
