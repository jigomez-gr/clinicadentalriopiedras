@{
    ViewData["Title"] = "Citas asignadas";
}

@section Estilos {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@ttskch/select2-bootstrap4-theme@1.5.2/dist/select2-bootstrap4.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <style>
        .acciones-container {
            display: flex;
            gap: 4px;
        }

        .btn-circle {
            width: 32px;
            height: 32px;
            padding: 0;
            border-radius: 50%;
            text-align: center;
            font-size: 14px;
            line-height: 32px;
            display: inline-block;
            vertical-align: middle;
        }

        #tbData {
            border-collapse: collapse !important;
        }

        @@media (max-width:768px) {
            #tbData thead th:first-child, #tbData tbody td:first-child {
                position: sticky;
                left: 0;
                background-color: #f8f9fa !important;
                z-index: 5;
                border-right: 2px solid #dee2e6;
            }
        }

        .dataTables_processing {
            background-color: #ffcccc !important;
            color: #d9534f !important;
            font-weight: bold !important;
            font-size: 1.2rem !important;
            border: 2px solid #d9534f !important;
            z-index: 9999 !important;
            top: 50% !important;
            height: auto !important;
            padding: 20px !important;
        }

        .tooltip-light {
            --bs-tooltip-bg: #fff;
            --bs-tooltip-color: #000;
            --bs-tooltip-opacity: 1;
        }

            .tooltip-light .tooltip-inner {
                border: 1px solid rgba(0,0,0,.15);
            }

        .star-rating-readonly {
            display: flex;
            gap: 2px;
        }

            .star-rating-readonly .star {
                font-size: 1.8rem;
                color: #ddd;
            }

                .star-rating-readonly .star.active {
                    color: #ffc107;
                }

            .star-rating-readonly .star-zero {
                font-size: 1rem;
                color: #999;
                align-self: center;
                margin-left: 5px;
            }
        /* Pantalla completa cámara IA */
        #docFullscreen {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: #000;
            z-index: 99999;
            flex-direction: column;
            overflow-y: auto;
        }

            #docFullscreen.activo {
                display: flex;
            }

            #docFullscreen .fs-toolbar {
                background: #1a1a2e;
                padding: 8px 12px;
                display: flex;
                align-items: center;
                gap: 8px;
                flex-wrap: wrap;
                flex-shrink: 0;
            }

            #docFullscreen .fs-area {
                flex: 1;
                min-height: 0;
                position: relative;
                background: #000;
            }

            #docFullscreen .fs-controls {
                background: #1a1a2e;
                padding: 8px 12px;
                flex-shrink: 0;
            }

            #docFullscreen .fs-resultado {
                background: #0f3460;
                color: #fff;
                padding: 12px;
                flex-shrink: 0;
                display: none;
                white-space: pre-line;
                font-size: .9rem;
                max-height: 35vh;
                overflow-y: auto;
            }

                #docFullscreen .fs-resultado.visible {
                    display: block;
                }
    </style>
}

<div class="container-fluid px-2 px-md-4">
    <h2 class="mt-4 mb-4 d-flex align-items-center">
        <span>Citas asignadas</span>
        <button type="button" class="btn btn-sm ms-auto" style="background-color:#ff8c00;color:#fff;border-color:#ff8c00;"
                onclick="openHelpVideo('Doctor_Horario.mp4')" data-bs-toggle="tooltip" title="Ayuda">
            <i class="fa fa-circle-question me-1"></i> Ayuda
        </button>
    </h2>
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-4">
                    <label class="form-label">Filtrar por estado</label>
                    <select class="form-select" id="cboEstadoCita">
                        <option value="1" selected>Pendiente</option>
                        <option value="2">Atendido</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table id="tbData" class="table table-striped table-bordered table-hover w-100 align-middle" style="width:100%">
                    <thead>
                        <tr>
                            <th>Acciones</th>
                            <th>Nº Cita</th>
                            <th>Fecha Cita</th>
                            <th>Hora Cita</th>
                            <th>Tipo</th>
                            <th>Paciente</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ===== PANTALLA COMPLETA CÁMARA ===== -->
<div id="docFullscreen">
    <div class="fs-toolbar">
        <button type="button" class="btn btn-outline-light btn-sm" id="fsBtnVolver">
            <i class="fas fa-arrow-left me-1"></i>Volver al modal
        </button>
        <span class="text-white small ms-2">Cámara — captura, recorta y analiza</span>
        <div class="ms-auto">
            <button type="button" class="btn btn-warning btn-sm d-none" id="fsBtnVerResultados">
                <i class="fas fa-eye me-1"></i>Ver resultados y volver
            </button>
        </div>
    </div>
    <div class="fs-area" id="fsArea">
        <!-- Stream -->
        <div id="fsStreamDiv" style="width:100%;height:100%;display:flex;flex-direction:column;">
            <video id="fsVideo" autoplay playsinline style="width:100%;flex:1;object-fit:cover;background:#000;"></video>
            <div style="background:#1a1a2e;padding:10px;display:flex;gap:10px;flex-wrap:wrap;">
                <button type="button" class="btn btn-primary" id="fsBtnCapturar">
                    <i class="fas fa-camera me-1"></i>Capturar foto
                </button>
                <button type="button" class="btn btn-outline-light" id="fsBtnVoltearFS">
                    <i class="fas fa-sync-alt me-1"></i>Voltear cámara
                </button>
            </div>
        </div>
        <!-- Cropper -->
        <div id="fsCropperDiv" style="display:none;width:100%;height:100%;">
            <img id="fsImgCropper" src="" alt="Recortar" style="max-width:100%;display:block;" />
        </div>
    </div>
    <div class="fs-controls" id="fsControles" style="display:none;">
        <div class="d-flex gap-2 align-items-center mb-2 flex-wrap">
            <span class="text-white small">Zoom:</span>
            <i class="fas fa-search-minus text-white"></i>
            <input type="range" id="fsSliderZoom" min="0.1" max="5" step="0.05" value="0.1"
                   class="form-range flex-grow-1" style="max-width:260px;" />
            <i class="fas fa-search-plus text-white"></i>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-light" id="fsBtnModeMover">
                    <i class="fas fa-hand-paper me-1"></i>Mover
                </button>
                <button type="button" class="btn btn-outline-light active" id="fsBtnModeRecortar">
                    <i class="fas fa-crop-alt me-1"></i>Recortar
                </button>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="fsBtnReset">
                <i class="fas fa-undo"></i> Reset
            </button>
            <button type="button" class="btn btn-success ms-auto" id="fsBtnAnalizarFS">
                <i class="fas fa-microscope me-1"></i>Analizar recorte con IA
            </button>
        </div>
    </div>
    <div class="fs-resultado" id="fsResultado"></div>
</div>

<!-- ===== MODAL ===== -->
<div class="modal fade" id="mdData" data-bs-backdrop="static" data-bs-keyboard="false"
     tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Resumen de la cita</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2 mb-2">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Nº Cita</label>
                        <input type="text" class="form-control fw-bold text-center" id="txtNumeroCita" disabled />
                    </div>
                    <div class="col-12 col-md-9">
                        <label class="form-label">Paciente</label>
                        <input type="text" class="form-control" id="txtPaciente" disabled>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-12 col-md-6">
                        <label class="form-label">Fecha cita</label>
                        <input type="text" class="form-control" id="txtFechaCitaResumen" disabled />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Hora cita</label>
                        <input type="text" class="form-control" id="txtHoraCitaResumen" disabled />
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-12 col-md-5">
                        <label class="form-label">Origen</label>
                        <input type="text" class="form-control" id="txtOrigenCita" disabled />
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-bold">Tipo de Cita</label>
                        <input type="text" class="form-control" id="txtTipoCita" disabled />
                    </div>
                    <div class="col-12 col-md-4 d-flex align-items-end">
                        <a href="#" target="_blank" class="btn btn-info btn-sm w-100 d-none" id="btnUnirseCalcom">
                            <i class="fas fa-video me-1"></i>Unirse a reunión virtual
                        </a>
                    </div>
                </div>
                <hr />
                <div class="mb-2">
                    <label class="form-label">Motivo del paciente</label>
                    <textarea class="form-control" id="txtRazonCitaUsr" rows="3" readonly></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label d-block">Documento del paciente</label>
                    <button type="button" id="btnVerDocPaciente" class="btn btn-outline-secondary btn-sm" disabled>
                        Ver documento del paciente
                    </button>
                    <small id="lblDocPacienteSin" class="text-muted ms-2 d-none">Sin documento.</small>
                    <small id="lblDocPacienteCon" class="text-success ms-2 d-none">✔ Disponible.</small>
                    <div class="mt-2" id="divImgPaciente" style="display:none;">
                        <img id="imgDocPaciente" src="" class="img-fluid rounded border" style="max-height:200px;object-fit:contain;" />
                    </div>
                </div>
                <hr />
                <div class="mb-2">
                    <label class="form-label fw-bold">Valoración del paciente</label>
                    <div class="star-rating-readonly" id="starRatingDisplay">
                        <span class="star" data-value="1">★</span><span class="star" data-value="2">★</span>
                        <span class="star" data-value="3">★</span><span class="star" data-value="4">★</span>
                        <span class="star" data-value="5">★</span>
                        <span class="star-zero" id="lblSinValoracion" style="display:none;">(Sin valoración)</span>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Opinión del paciente</label>
                    <textarea class="form-control" id="txtOpinionDoctorYClinica" rows="2" readonly></textarea>
                </div>
                <hr />
                <div class="alert alert-primary" role="alert">
                    Escriba las indicaciones para el paciente y adjunte documento si lo desea.
                </div>
                <div class="mb-3">
                    <label class="form-label">Indicaciones del doctor</label>
                    <textarea class="form-control" id="txtIndicaciones" rows="4"></textarea>
                </div>
                <div class="mb-2">
                    <label class="form-label d-block">Documento del doctor</label>
                    <button type="button" id="btnVerDocDoctor" class="btn btn-outline-secondary btn-sm" disabled>
                        Ver documento del doctor
                    </button>
                    <small id="lblDocDoctorSin" class="text-muted ms-2 d-none">Sin documento.</small>
                    <small id="lblDocDoctorCon" class="text-success ms-2 d-none">✔ Disponible.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Adjuntar / actualizar documento del doctor</label>
                    <input type="file" class="form-control" id="fileDocDoctor" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx">
                </div>
                <hr />
                <!-- ── Análisis IA ── -->
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        <i class="fas fa-robot me-1 text-success"></i>Análisis IA
                    </label>
                    <div class="mb-2">
                        <select class="form-select form-select-sm" id="docServicioIA" style="max-width:220px;">
                            <option value="dental">🦷 Dental (boca/encías)</option>
                            <option value="rx">🩻 Radiografía dental</option>
                            <option value="derma">🔬 Dermatología</option>
                            <option value="belleza">✨ Estética</option>
                            <option value="general">🏥 General</option>
                        </select>
                    </div>
                    <ul class="nav nav-tabs nav-sm mb-2">
                        <li class="nav-item">
                            <button class="nav-link active small" data-bs-toggle="tab" data-bs-target="#docTabCamara">
                                <i class="fas fa-camera me-1"></i>Cámara
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link small" data-bs-toggle="tab" data-bs-target="#docTabPegar">
                                <i class="fas fa-paste me-1"></i>Pegar captura
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link small" data-bs-toggle="tab" data-bs-target="#docTabFichero">
                                <i class="fas fa-file-image me-1"></i>Fichero
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link small" data-bs-toggle="tab" data-bs-target="#docTabBD">
                                <i class="fas fa-database me-1"></i>Doc. paciente BD
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link small" data-bs-toggle="tab" data-bs-target="#docTabDoctorBD">
                                <i class="fas fa-user-md me-1"></i>Doc. doctor BD
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <!-- Tab Cámara — abre pantalla completa -->
                        <div class="tab-pane fade show active" id="docTabCamara">
                            <button type="button" class="btn btn-success" id="docBtnAbrirCamara">
                                <i class="fas fa-camera me-1"></i>Abrir cámara a pantalla completa
                            </button>
                            <p class="text-muted small mt-2 mb-1">
                                Se abrirá pantalla completa para capturar, recortar con zoom y analizar.
                                Al terminar pulsa "Ver resultados y volver".
                            </p>
                            <div id="docCamaraMiniPreview" class="d-none mt-1">
                                <img id="docCamaraMiniImg" src="" style="max-height:70px;border-radius:6px;border:2px solid #198754;" />
                                <span class="badge bg-success ms-2">✓ Imagen capturada</span>
                            </div>
                        </div>
                        <!-- Tab Pegar -->
                        <div class="tab-pane fade" id="docTabPegar">
                            <div class="alert alert-info small py-2">
                                <i class="fas fa-info-circle me-1"></i>
                                Haz PrintScreen de la reunión virtual, clic en el área y pega con <kbd>Ctrl+V</kbd>.
                            </div>
                            <div id="docPasteArea" tabindex="0"
                                 style="min-height:100px;border:2px dashed #6c757d;border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;background:#f8f9fa;"
                                 class="mb-2">
                                <span class="text-muted small">Clic aquí y pega (Ctrl+V)</span>
                            </div>
                            <div id="docPastePreview" class="d-none mb-2">
                                <img id="docPasteImg" src="" style="max-width:100%;max-height:180px;border-radius:8px;border:1px solid #dee2e6;" />
                            </div>
                            <button type="button" class="btn btn-success btn-sm d-none" id="docBtnAnalizarPaste">
                                <i class="fas fa-microscope me-1"></i>Analizar captura con IA
                            </button>
                        </div>
                        <!-- Tab Fichero -->
                        <div class="tab-pane fade" id="docTabFichero">
                            <input type="file" class="form-control form-control-sm mb-2" id="docFileIA" accept="image/*" />
                            <button type="button" class="btn btn-success btn-sm" id="docBtnAnalizarFichero">
                                <i class="fas fa-microscope me-1"></i>Analizar fichero con IA
                            </button>
                        </div>
                        <!-- Tab BD Paciente -->
                        <div class="tab-pane fade" id="docTabBD">
                            <p class="small text-muted mb-2" id="docLblBDInfo">Se analizará el documento del paciente en BD.</p>
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="button" class="btn btn-success btn-sm" id="docBtnAnalizarBD" disabled>
                                    <i class="fas fa-database me-1"></i>Analizar doc. paciente con IA
                                </button>
                                <button type="button" class="btn btn-outline-success btn-sm" id="docBtnAnalizarBDSeleccion" disabled>
                                    <i class="fas fa-crop-alt me-1"></i>Analizar selección con IA
                                </button>
                                <button type="button" class="btn btn-outline-warning btn-sm" id="docBtnAnalizarBDYolo" disabled>
                                    <i class="fas fa-robot me-1"></i>Analizar selección con IA + YOLO
                                </button>
                            </div>
                        </div>
                        <!-- Tab BD Doctor -->
                        <div class="tab-pane fade" id="docTabDoctorBD">
                            <p class="small text-muted mb-2" id="docLblDoctorBDInfo">Se analizará el documento del doctor en BD.</p>
                            <button type="button" class="btn btn-success btn-sm" id="docBtnAnalizarDoctorBD" disabled>
                                <i class="fas fa-user-md me-1"></i>Analizar doc. doctor con IA
                            </button>
                        </div>
                    </div>
                    <!-- Resultado IA -->
                    <div id="docResultadoIA" class="d-none mt-2">
                        <label class="form-label fw-bold text-success">
                            <i class="fas fa-check-circle me-1"></i>Resultado del análisis IA:
                        </label>
                        <div class="alert alert-success small py-2 mb-0" id="docTextoIA"
                             style="white-space:pre-line;max-height:220px;overflow-y:auto;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnTerminarCita">
                    Guardar / marcar como atendida
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        // ── Variables globales ────────────────────────────────────────────────
        var docPacienteBase64 = null, docPacienteContentType = null;
        var docDoctorBase64   = null, docDoctorContentType   = null;
        var docImagenBlob     = null;
        var urlCalcom         = null;
        var docIdCitaSeleccionada = 0;
        var fsCropper = null, fsStream = null, fsFacingMode = "environment";

        (function () {
            "use strict";
            window.openHelpVideo = function (fileName) {
                const w = 900, h = 520;
                window.open("/helps/" + encodeURIComponent(fileName), "helpVideo",
                    `width=${w},height=${h},left=${Math.max(0,(screen.width-w)/2)},top=${Math.max(0,(screen.height-h)/2)},resizable=yes`);
            };
        })();

        function initTooltips(scope) {
            (scope || document).querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
                if (!bootstrap.Tooltip.getInstance(el)) new bootstrap.Tooltip(el);
            });
        }
        function mostrarValoracion(valor) {
            document.querySelectorAll('#starRatingDisplay .star').forEach(s =>
                s.classList.toggle('active', parseInt(s.getAttribute('data-value')) <= valor));
            document.getElementById('lblSinValoracion').style.display = valor === 0 ? 'inline' : 'none';
        }

        // ── IIFE principal ────────────────────────────────────────────────────
        (function () {
            let tablaData, idCitaSeleccionada = 0;
            const controlador = "Doctor", modal = "mdData";

            $(document).ready(function () {
                initTooltips();
                tablaData = $('#tbData').DataTable({
                    processing: true, serverSide: true, scrollX: true,
                    ajax: {
                        url: '/' + controlador + '/ListaCitasAsignadasServerSide',
                        type: 'POST', dataType: 'json',
                        data: function (d) { d.idEstadoCita = parseInt($('#cboEstadoCita').val() || '1'); return d; }
                    },
                    columns: [
                        { data: "idCita", width: "80px", orderable: false,
                          render: () => `<div class="acciones-container"><button type="button" class="btn btn-warning btn-circle text-white btn-indicaciones" title="Indicaciones"><i class="fas fa-notes-medical"></i></button></div>` },
                        { data: "idCita", width: "80px", title: "Nº Cita" },
                        { data: "fechaCita", width: "150px" },
                        { data: "horaCita",  width: "100px" },
                        { data: "tipoDeCita", width: "100px",
                          render: v => ({ P: '<span class="badge bg-primary">Presencial</span>', T: '<span class="badge bg-warning text-dark">Telefónica</span>', V: '<span class="badge bg-info text-dark">Virtual</span>' }[v] || v || '') },
                        { data: "usuario", render: d => (d?.nombre||"")+" "+(d?.apellido||"") },
                        { data: "estadoCita", render: d => !d?.nombre ? "" : d.nombre==="Pendiente" ? `<span class="badge bg-primary">${d.nombre}</span>` : `<span class="badge bg-success">${d.nombre}</span>` }
                    ],
                    order: [[2,"desc"],[3,"asc"]],
                    language: { url: "https://cdn.datatables.net/plug-ins/1.11.5/i18n/es-ES.json" },
                    drawCallback: function () { initTooltips(document.getElementById("tbData")); }
                });

                $("#cboEstadoCita").on("change", () => tablaData.ajax.reload());

                // Abrir modal
                $("#tbData tbody").on("click", ".btn-indicaciones", function () {
                    const data = tablaData.row($(this).closest('tr')).data();
                    idCitaSeleccionada = data.idCita;
                    docIdCitaSeleccionada = data.idCita;

                    $("#txtNumeroCita").val(data.idCita||"");
                    $("#txtPaciente").val((data.usuario?.nombre||"")+" "+(data.usuario?.apellido||""));
                    $("#txtFechaCitaResumen").val(data.fechaCita||"");
                    $("#txtHoraCitaResumen").val(data.horaCita||"");
                    $("#txtOrigenCita").val(data.origenCita||"");
                    $("#txtRazonCitaUsr").val(data.razonCitaUsr||"");
                    $("#txtIndicaciones").val(data.indicaciones||"");
                    mostrarValoracion(data.valDoctorCita ?? 3);
                    $("#txtOpinionDoctorYClinica").val(data.opinionDoctorYClinica||"");

                    // Tipo + Cal.com
                    const tipoMap = { P:"Presencial", T:"Telefónica", V:"Virtual" };
                    $("#txtTipoCita").val(tipoMap[data.tipoDeCita]||data.tipoDeCita||"Presencial");
                    const calUid = data.calBookingUid || null;
                    urlCalcom = calUid ? `https://app.cal.eu/video/${calUid}` : (data.urlCitaOTelefono||null);
                    urlCalcom ? $("#btnUnirseCalcom").removeClass("d-none").attr("href", urlCalcom)
                              : $("#btnUnirseCalcom").addClass("d-none");

                    // Diagnóstico IA previo
                    if (data.diagnosticoIA) {
                        document.getElementById("docTextoIA").innerText = data.diagnosticoIA;
                        document.getElementById("docResultadoIA").classList.remove("d-none");
                    } else {
                        document.getElementById("docTextoIA").innerText = "";
                        document.getElementById("docResultadoIA").classList.add("d-none");
                    }

                    // Documento paciente
                    docPacienteBase64      = data.documentoCitaUsr || null;
                    docPacienteContentType = data.contentType || "application/octet-stream";
                    if (docPacienteBase64) {
                        $("#btnVerDocPaciente").prop("disabled",false).addClass("btn-outline-success").removeClass("btn-outline-secondary");
                        $("#lblDocPacienteSin").addClass("d-none"); $("#lblDocPacienteCon").removeClass("d-none");
                        if ((data.contentType||"").toLowerCase().includes("image")) {
                            $("#imgDocPaciente").attr("src", `data:${data.contentType};base64,${data.documentoCitaUsr}`);
                            $("#divImgPaciente").show();
                        } else { $("#divImgPaciente").hide(); $("#imgDocPaciente").attr("src",""); }
                        const esImg = (data.contentType||"").startsWith("image/");
                        $("#docBtnAnalizarBD, #docBtnAnalizarBDSeleccion, #docBtnAnalizarBDYolo").prop("disabled", !esImg);
                        $("#docLblBDInfo").text(esImg ? "Se analizará la imagen del paciente en BD." : "El doc. del paciente no es una imagen.");
                    } else {
                        $("#btnVerDocPaciente").prop("disabled",true).removeClass("btn-outline-success").addClass("btn-outline-secondary");
                        $("#lblDocPacienteSin").removeClass("d-none"); $("#lblDocPacienteCon").addClass("d-none");
                        $("#divImgPaciente").hide(); $("#imgDocPaciente").attr("src","");
                        $("#docBtnAnalizarBD, #docBtnAnalizarBDSeleccion, #docBtnAnalizarBDYolo").prop("disabled", true);
                        $("#docLblBDInfo").text("No hay documento del paciente en BD.");
                    }

                    // Documento doctor
                    docDoctorBase64      = data.docIndicacionesDoctor || null;
                    docDoctorContentType = data.contentTypeDoctor || "application/octet-stream";
                    if (docDoctorBase64) {
                        $("#btnVerDocDoctor").prop("disabled",false).addClass("btn-outline-success").removeClass("btn-outline-secondary");
                        $("#lblDocDoctorSin").addClass("d-none"); $("#lblDocDoctorCon").removeClass("d-none");
                        const esImgDoc = (data.contentTypeDoctor||"").startsWith("image/");
                        $("#docBtnAnalizarDoctorBD").prop("disabled", !esImgDoc);
                        $("#docLblDoctorBDInfo").text(esImgDoc ? "Se analizará el documento del doctor en BD." : "El doc. del doctor no es una imagen.");
                    } else {
                        $("#btnVerDocDoctor").prop("disabled",true).removeClass("btn-outline-success").addClass("btn-outline-secondary");
                        $("#lblDocDoctorSin").removeClass("d-none"); $("#lblDocDoctorCon").addClass("d-none");
                        $("#docBtnAnalizarDoctorBD").prop("disabled", true);
                        $("#docLblDoctorBDInfo").text("No hay documento del doctor en BD.");
                    }

                    docImagenBlob = null;
                    $("#fileDocDoctor").val("");
                    $("#docCamaraMiniPreview").addClass("d-none");
                    $("#docPastePreview, #docBtnAnalizarPaste").addClass("d-none");

                    const esAtendido = data.estadoCita?.nombre === "Atendido";
                    $(".alert-primary").text(esAtendido
                        ? "La cita ya está ATENDIDA, pero puede actualizar las indicaciones y el documento."
                        : "Escriba las indicaciones para el paciente y adjunte un documento si lo desea.");

                    $("#" + modal).modal("show");
                });

                // Ver documentos
                $("#btnVerDocPaciente").on("click", function () {
                    if (!docPacienteBase64) return;
                    const b = atob(docPacienteBase64), a = new Uint8Array(b.length);
                    for (let i=0;i<b.length;i++) a[i]=b.charCodeAt(i);
                    window.open(URL.createObjectURL(new Blob([a],{type:docPacienteContentType})),"_blank");
                });
                $("#btnVerDocDoctor").on("click", function () {
                    if (!docDoctorBase64) return;
                    const b = atob(docDoctorBase64), a = new Uint8Array(b.length);
                    for (let i=0;i<b.length;i++) a[i]=b.charCodeAt(i);
                    window.open(URL.createObjectURL(new Blob([a],{type:docDoctorContentType})),"_blank");
                });

                // Guardar
                $("#btnTerminarCita").on("click", function () {
                    if ($("#txtIndicaciones").val().trim()==="")
                        return Swal.fire("Importante","Debe ingresar las indicaciones.","warning");
                    fetch("/"+controlador+"/CambiarEstado", {
                        method:"POST", headers:{"Content-Type":"application/json;charset=utf-8"},
                        body: JSON.stringify({ IdCita:idCitaSeleccionada, EstadoCita:{IdEstadoCita:2}, Indicaciones:$("#txtIndicaciones").val().trim() })
                    }).then(r=>r.json()).then(rj => {
                        if (rj.data==="") {
                            const file = document.getElementById("fileDocDoctor").files[0];
                            const tieneDoc = docDoctorBase64 && docDoctorBase64.length > 0;
                            function guardarDoc(b64, tipo) {
                                fetch("/"+controlador+"/GuardarDocumentoDoctor", {
                                    method:"POST", headers:{"Content-Type":"application/json;charset=utf-8"},
                                    body: JSON.stringify({IdCita:idCitaSeleccionada, DocIndicacionesDoctor:b64, ContentTypeDoctor:tipo})
                                }).then(r=>r.json()).then(()=>{
                                    Swal.fire("Listo!","Cita marcada como atendida y documento guardado.","success");
                                    $("#"+modal).modal("hide"); tablaData.ajax.reload();
                                });
                            }
                            if (file) {
                                const rd = new FileReader();
                                rd.onload = e => guardarDoc(e.target.result.split(",")[1], file.type);
                                rd.readAsDataURL(file);
                            } else if (docImagenBlob && !tieneDoc) {
                                const rd = new FileReader();
                                rd.onload = e => guardarDoc(e.target.result.split(",")[1], docImagenBlob.type||"image/jpeg");
                                rd.readAsDataURL(docImagenBlob);
                            } else {
                                Swal.fire("Listo!","La cita fue marcada como ATENDIDO.","success");
                                $("#"+modal).modal("hide"); tablaData.ajax.reload();
                            }
                        } else { Swal.fire("Error!",rj.data,"warning"); }
                    });
                });

                // Cerrar modal
                document.getElementById("mdData").addEventListener("hidden.bs.modal", function () {
                    fsCerrarPantallaCompleta();
                    docPacienteBase64 = null; docDoctorBase64 = null;
                    docImagenBlob = null; urlCalcom = null; docIdCitaSeleccionada = 0;
                    document.getElementById("docTextoIA").innerText = "";
                    document.getElementById("docResultadoIA").classList.add("d-none");
                    document.getElementById("docCamaraMiniPreview").classList.add("d-none");
                    document.getElementById("docPastePreview").classList.add("d-none");
                    document.getElementById("docBtnAnalizarPaste").classList.add("d-none");
                });
            });
        })();

        // ── Pantalla completa ────────────────────────────────────────────────
        function fsAbrirPantallaCompleta() {
            document.getElementById("docFullscreen").classList.add("activo");
            document.body.style.overflow = "hidden";
            document.getElementById("fsStreamDiv").style.display = "flex";
            document.getElementById("fsCropperDiv").style.display = "none";
            document.getElementById("fsControles").style.display = "none";
            document.getElementById("fsResultado").classList.remove("visible");
            document.getElementById("fsBtnVerResultados").classList.add("d-none");
            fsAbrirStream();
        }
        function fsCerrarPantallaCompleta() {
            fsCerrarStream();
            if (fsCropper) { fsCropper.destroy(); fsCropper = null; }
            document.getElementById("docFullscreen").classList.remove("activo");
            document.body.style.overflow = "";
        }
        function fsAbrirStream() {
            fsCerrarStream();
            navigator.mediaDevices.getUserMedia({
                video: { facingMode: fsFacingMode, width:{ideal:1280}, height:{ideal:720} }
            }).then(s => {
                fsStream = s;
                document.getElementById("fsVideo").srcObject = s;
            }).catch(e => Swal.fire("Error","No se pudo acceder a la cámara: "+e.message,"error"));
        }
        function fsCerrarStream() {
            if (fsStream) { fsStream.getTracks().forEach(t=>t.stop()); fsStream=null; }
        }

        document.addEventListener("DOMContentLoaded", function () {

            // Botón abrir pantalla completa
            document.getElementById("docBtnAbrirCamara").addEventListener("click", fsAbrirPantallaCompleta);

            // Botones pantalla completa
            document.getElementById("fsBtnVolver").addEventListener("click", fsCerrarPantallaCompleta);

            document.getElementById("fsBtnVoltearFS").addEventListener("click", function () {
                fsFacingMode = fsFacingMode==="environment" ? "user" : "environment";
                fsAbrirStream();
            });

            document.getElementById("fsBtnCapturar").addEventListener("click", function () {
                const video = document.getElementById("fsVideo");
                const canvas = document.createElement("canvas");
                canvas.width = video.videoWidth; canvas.height = video.videoHeight;
                canvas.getContext("2d").drawImage(video, 0, 0);
                fsCerrarStream();
                document.getElementById("fsStreamDiv").style.display = "none";
                const img = document.getElementById("fsImgCropper");
                img.src = canvas.toDataURL("image/jpeg", 0.92);
                document.getElementById("fsCropperDiv").style.display = "block";
                document.getElementById("fsControles").style.display = "block";
                if (fsCropper) { fsCropper.destroy(); fsCropper=null; }
                fsCropper = new Cropper(img, {
                    aspectRatio:NaN, viewMode:1, autoCropArea:0.5,
                    responsive:true, movable:true, zoomable:true,
                    cropBoxMovable:true, cropBoxResizable:true, dragMode:"crop"
                });
                document.getElementById("fsSliderZoom").value = 0.1;
            });

            document.getElementById("fsSliderZoom").addEventListener("input", function() {
                if (fsCropper) fsCropper.zoomTo(parseFloat(this.value));
            });
            document.getElementById("fsBtnReset").addEventListener("click", function() {
                if (fsCropper) { fsCropper.reset(); document.getElementById("fsSliderZoom").value=0.1; }
            });
            document.getElementById("fsBtnModeMover").addEventListener("click", function() {
                if (!fsCropper) return;
                fsCropper.setDragMode("move");
                this.classList.add("active");
                document.getElementById("fsBtnModeRecortar").classList.remove("active");
            });
            document.getElementById("fsBtnModeRecortar").addEventListener("click", function() {
                if (!fsCropper) return;
                fsCropper.setDragMode("crop");
                this.classList.add("active");
                document.getElementById("fsBtnModeMover").classList.remove("active");
            });

            document.getElementById("fsBtnAnalizarFS").addEventListener("click", function() {
                if (!fsCropper) { Swal.fire("Aviso","Primero capture una foto.","warning"); return; }
                const canvas = fsCropper.getCroppedCanvas({ maxWidth:1600, maxHeight:1600 });
                const mx = Math.round(canvas.width*0.10), my = Math.round(canvas.height*0.10);
                const full = document.createElement("canvas");
                full.width = canvas.width+mx*2; full.height = canvas.height+my*2;
                full.getContext("2d").drawImage(canvas, mx, my);
                const btn = this;
                btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Analizando...';
                full.toBlob(function(blob) {
                    docImagenBlob = blob;
                    document.getElementById("docCamaraMiniImg").src = URL.createObjectURL(blob);
                    document.getElementById("docCamaraMiniPreview").classList.remove("d-none");
                    fsAnalizarBlob(blob, btn);
                }, "image/jpeg", 0.92);
            });

            document.getElementById("fsBtnVerResultados").addEventListener("click", function() {
                fsCerrarPantallaCompleta();
                setTimeout(() => {
                    const txtInd = document.getElementById("txtIndicaciones");
                    const diag = document.getElementById("docTextoIA").innerText;
                    if (diag && txtInd.value.trim()==="") txtInd.value = diag;
                    else if (diag) txtInd.value += "\n\n[IA] " + diag;
                    if (diag) { txtInd.focus(); txtInd.scrollIntoView({behavior:"smooth"}); }
                    document.getElementById("docResultadoIA").scrollIntoView({behavior:"smooth"});
                }, 350);
            });

            function fsAnalizarBlob(blob, btn) {
                const servicio = document.getElementById("docServicioIA").value || "dental";
                const razon    = document.getElementById("txtRazonCitaUsr")?.value || "";
                const contexto = razon ? `El paciente describe: "${razon}". Analiza la imagen teniendo en cuenta este contexto.`
                                       : "Analiza esta imagen clínica y describe los hallazgos observables.";
                const form = new FormData();
                form.append("idCita", docIdCitaSeleccionada);
                form.append("imagen", blob, "imagen.jpg");
                form.append("servicio", servicio);
                form.append("contexto", contexto);
                fetch("/Citas/AnalizarImagenIA", { method:"POST", body:form })
                .then(r=>r.json())
                .then(res => {
                    if (btn) { btn.disabled=false; btn.innerHTML='<i class="fas fa-microscope me-1"></i>Analizar recorte con IA'; }
                    if (res.ok) {
                        document.getElementById("fsResultado").innerText = res.diagnostico;
                        document.getElementById("fsResultado").classList.add("visible");
                        document.getElementById("fsBtnVerResultados").classList.remove("d-none");
                        document.getElementById("docTextoIA").innerText = res.diagnostico;
                        document.getElementById("docResultadoIA").classList.remove("d-none");
                        if (document.getElementById("txtIndicaciones").value.trim()==="")
                            document.getElementById("txtIndicaciones").value = res.diagnostico;
                    } else { Swal.fire("Error IA", res.msg||"Error desconocido", "error"); }
                })
                .catch(() => {
                    if (btn) { btn.disabled=false; btn.innerHTML='<i class="fas fa-microscope me-1"></i>Analizar recorte con IA'; }
                    Swal.fire("Error","Fallo de comunicación.","error");
                });
            }

            // ── Pegar captura ─────────────────────────────────────────────────
            const pasteArea = document.getElementById("docPasteArea");
            pasteArea.addEventListener("click", () => pasteArea.focus());
            pasteArea.addEventListener("paste", function(e) {
                for (const item of (e.clipboardData?.items||[])) {
                    if (item.type.startsWith("image/")) {
                        const blob = item.getAsFile();
                        docImagenBlob = blob;
                        document.getElementById("docPasteImg").src = URL.createObjectURL(blob);
                        document.getElementById("docPastePreview").classList.remove("d-none");
                        document.getElementById("docBtnAnalizarPaste").classList.remove("d-none");
                        pasteArea.querySelector("span").textContent = "✔ Captura pegada. Pulse Analizar.";
                        break;
                    }
                }
            });
            document.getElementById("docBtnAnalizarPaste").addEventListener("click", function() {
                if (docImagenBlob) docAnalizarBlob(docImagenBlob);
            });

            // ── Fichero ───────────────────────────────────────────────────────
            document.getElementById("docBtnAnalizarFichero").addEventListener("click", function() {
                const file = document.getElementById("docFileIA").files[0];
                if (!file) { Swal.fire("Aviso","Seleccione un fichero de imagen.","warning"); return; }
                if (!file.type.startsWith("image/")) { Swal.fire("Aviso","Solo imágenes.","warning"); return; }
                docAnalizarBlob(file);
            });

            // ── BD ────────────────────────────────────────────────────────────
            function blobDesdePacienteBD() {
                if (!docPacienteBase64) return null;
                const b=atob(docPacienteBase64), a=new Uint8Array(b.length);
                for(let i=0;i<b.length;i++) a[i]=b.charCodeAt(i);
                return new Blob([a],{type:docPacienteContentType||"image/jpeg"});
            }
            document.getElementById("docBtnAnalizarBD").addEventListener("click", () => { const bl=blobDesdePacienteBD(); if(bl) docAnalizarBlob(bl); });
            document.getElementById("docBtnAnalizarBDSeleccion").addEventListener("click", () => { const bl=blobDesdePacienteBD(); if(bl) docAnalizarBlob(bl); });
            document.getElementById("docBtnAnalizarBDYolo").addEventListener("click", () => { const bl=blobDesdePacienteBD(); if(bl) docAnalizarBlob(bl); });
            document.getElementById("docBtnAnalizarDoctorBD").addEventListener("click", function() {
                if (!docDoctorBase64) return;
                const b=atob(docDoctorBase64), a=new Uint8Array(b.length);
                for(let i=0;i<b.length;i++) a[i]=b.charCodeAt(i);
                docAnalizarBlob(new Blob([a],{type:docDoctorContentType||"image/jpeg"}));
            });

            // ── Función común análisis ────────────────────────────────────────
            function docAnalizarBlob(blob) {
                if (!docIdCitaSeleccionada) { Swal.fire("Aviso","No hay cita seleccionada.","warning"); return; }
                Swal.fire({ title:"Analizando con IA...", allowOutsideClick:false, didOpen:()=>Swal.showLoading() });
                const servicio = document.getElementById("docServicioIA").value || "dental";
                const razon    = document.getElementById("txtRazonCitaUsr")?.value || "";
                const contexto = razon ? `El paciente describe: "${razon}". Analiza la imagen teniendo en cuenta este contexto.`
                                       : "Analiza esta imagen clínica y describe los hallazgos observables.";
                const form = new FormData();
                form.append("idCita", docIdCitaSeleccionada);
                form.append("imagen", blob, "imagen.jpg");
                form.append("servicio", servicio);
                form.append("contexto", contexto);
                fetch("/Citas/AnalizarImagenIA", { method:"POST", body:form })
                .then(r=>r.json())
                .then(res => {
                    Swal.close();
                    if (res.ok) {
                        document.getElementById("docTextoIA").innerText = res.diagnostico;
                        document.getElementById("docResultadoIA").classList.remove("d-none");
                        document.getElementById("docResultadoIA").scrollIntoView({behavior:"smooth"});
                        if (document.getElementById("txtIndicaciones").value.trim()==="")
                            document.getElementById("txtIndicaciones").value = res.diagnostico;
                    } else { Swal.fire("Error IA", res.msg||"Error desconocido","error"); }
                })
                .catch(() => Swal.fire("Error","Fallo de comunicación con el servidor.","error"));
            }
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
}
