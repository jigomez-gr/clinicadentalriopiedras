        // Usamos el ID exacto que tienes en tu HTML: btnConfirmarCancelPac
             document.addEventListener("click", async function (e) {
            // Verificamos si el elemento clicado es nuestro botón de confirmación
            if (e.target && e.target.id === "btnConfirmarCancelPac") {
                e.preventDefault();

                // Leemos los valores usando JavaScript nativo para máxima compatibilidad
                const elId = document.getElementById("cancelarIdCita");
                const elMotivo = document.getElementById("cancelarMotivo");

                if (!elId) return;

                const idCita = elId.value;
                const motivoRaw = elMotivo ? elMotivo.value : "";
                const motivo = motivoRaw.trim();

                if (!motivo) {
                    Swal.fire("Atención", "Debe indicar un motivo para cancelar.", "warning");
                    return;
                }

                // Bloqueamos la interfaz con Swal (que sí suele estar cargado globalmente)
                Swal.fire({
                    title: 'Procesando...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                try {
                    // Llamada al endpoint de Agenda
                    const response = await fetch(`/Citas/CancelarCitaAgenda?idCita=${idCita}&motivo=${encodeURIComponent(motivo)}`, {
                        method: "POST"
                    });

                    const result = await response.json();

                    if (result.ok) {
                        // Cerramos el modal usando la referencia global declarada al inicio
                        if (window.modalCancelarObj) {
                            window.modalCancelarObj.hide();
                        }
                        iniciarPollingCancelacion(result.idAccion);
                    } else {
                        Swal.fire("Error", result.mensaje || "Error desconocido", "error");
                    }
                } catch (error) {
                    console.error("Error en la petición:", error);
                    Swal.fire("Error", "No se pudo conectar con el servidor.", "error");
                }
            }
        });

        /* La función de polling permanece igual ya que usa fetch nativo */
        function iniciarPollingCancelacion(idAccion) {
            console.log("--- Iniciando Polling de Cancelación ---");
            let intentos = 0;

            const intervalo = setInterval(async () => {
                intentos++;
                try {
                    const check = await fetch(`/Citas/ConsultarEstadoAccion?id=${idAccion}`);
                    const res = await check.json();
                    const estado = (res.status || "").trim().toUpperCase();

                    if (estado === 'S' || estado === 'Z' || intentos > 20) {
                        clearInterval(intervalo);

                        let titulo = (estado === 'S') ? "Éxito" : "Info";
                        let texto = (estado === 'S') ? "Cita cancelada correctamente." : "Sincronización finalizada.";

                        Swal.fire(titulo, texto, (estado === 'S' ? "success" : "info")).then(() => {
                            // Si verAgenda es una función de jQuery, la llamamos con seguridad
                            if (typeof verAgenda === "function") {
                                verAgenda();
                            } else {
                                window.location.reload();
                            }
                        });
                    }
                } catch (err) {
                    console.error("Error en el polling:", err);
                }
            }, 3000);

        }


