              Swal.fire({
                  title: "OK",
                  text: "Slot creado: " + horaInput,
                  icon: "success",
                  timer: 1500,          // Hacemos que el mensaje desaparezca solo para que sea más fluido
                  showConfirmButton: false
              });

              // ✅ CORRECCIÓN: Damos 400ms de oxígeno al VPS para que cierre la transacción
              // antes de recargar la pantalla con verAgenda() (que ya tiene los anti-cachés)
              setTimeout(async () => {
                  await verAgenda();
              }, 800);
          }
           function getIdDoctorPantalla() {
