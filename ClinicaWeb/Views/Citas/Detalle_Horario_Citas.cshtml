                        document.getElementById("dhcTextoIA").innerText=res.diagnostico;
                        document.getElementById("dhcResultadoIA").classList.remove("d-none");
                        document.getElementById("dhcResultadoIA").scrollIntoView({behavior:"smooth"});
                        document.getElementById("dhcFsResultado").innerText=res.diagnostico;
                        document.getElementById("dhcFsResultado").style.display="block";
                        const ind=document.getElementById("citaIndicaciones");
                        if(ind&&ind.value.trim()==="")ind.value=res.diagnostico;
                        if(cb)cb();
                    } else {Swal.fire("Error IA",res.msg||"Error","error");if(cb)cb();}
                }).catch(()=>{Swal.fire("Error","Fallo de comunicación.","error");if(cb)cb();});
            }
            // Guardar tipo de cita
            document.addEventListener("DOMContentLoaded", function() {
                const btnGuardarTipo = document.getElementById("citaBtnGuardarTipo");
                if (btnGuardarTipo) {
                    btnGuardarTipo.addEventListener("click", function() {
                        if (!dhcIdCita) { Swal.fire("Aviso","No hay cita seleccionada.","warning"); return; }
                        const tipo = document.getElementById("citaTipoCita").value;
                        fetch(`/Citas/ActualizarTipoCita?idCita=${dhcIdCita}&tipoDeCita=${tipo}`, { method:"POST" })
                        .then(r=>r.json())
                        .then(res=>{
                            if(res.ok) Swal.fire("Guardado","Tipo de cita actualizado.","success");
                            else Swal.fire("Error", res.msg||"Error al guardar","error");
                        })
                        .catch(()=>Swal.fire("Error","Fallo de comunicación.","error"));
                    });
                }
            });

            // ═══════════════════════════════════════════
            // SUBMODAL IA
            // ═══════════════════════════════════════════
            var iaIdCita = 0;
            var iaPacBase64 = null, iaPacContentType = null;
            var iaDocBase64 = null, iaDocContentType = null;
            var iaImagenBlob = null;

            function abrirModalIA(slot) {
                console.log("abrirModalIA llamado, slot=", slot);
                const mdIAEl = document.getElementById("mdIA");
                console.log("mdIA elemento=", mdIAEl);
                const cita = (slot && slot.cita) ? slot.cita : slot;
                iaIdCita = cita.idCita || slot.idCita || 0;
                console.log("iaIdCita=", iaIdCita);

                // Nombre paciente en título
                const pacNom = (cita.paciente || slot.paciente || "").trim();
                document.getElementById("iaModalPaciente").textContent = pacNom;

                // Cargar indicaciones actuales
                document.getElementById("iaIndicaciones").value = (cita.indicaciones || "").trim();

                // Cargar resultado IA previo si existe
                if (cita.diagnosticoIA) {
                    document.getElementById("iaTextoIA").innerText = cita.diagnosticoIA;
                    document.getElementById("iaResultadoIA").classList.remove("d-none");
                } else {
                    document.getElementById("iaTextoIA").innerText = "";
                    document.getElementById("iaResultadoIA").classList.add("d-none");
                }

                // Sincronizar servicio IA
                const dhcSvc = document.getElementById("dhcServicioIA");
                const iaSvc = document.getElementById("iaServicioIA");
                if (dhcSvc && iaSvc) iaSvc.value = dhcSvc.value;

                // Documentos BD
                iaPacBase64 = cita.documentoCitaUsr || null;
                iaPacContentType = cita.contentType || "application/octet-stream";
                iaDocBase64 = cita.docIndicacionesDoctor || null;
                iaDocContentType = cita.contentTypeDoctor || "application/octet-stream";

                const esImgPac = !!(iaPacBase64 && (iaPacContentType||"").startsWith("image/"));
                document.getElementById("iaBtnAnalizarBDPac").disabled = !esImgPac;
                document.getElementById("iaLblBDPac").textContent = esImgPac
                    ? "Se analizará la imagen del paciente en BD."
                    : (iaPacBase64 ? "El doc. no es una imagen." : "No hay documento del paciente en BD.");

                const esImgDoc = !!(iaDocBase64 && (iaDocContentType||"").startsWith("image/"));
                document.getElementById("iaBtnAnalizarBDDoc").disabled = !esImgDoc;
                document.getElementById("iaBtnDescDocDoctor").disabled = !iaDocBase64;
                document.getElementById("iaLblBDDoc").textContent = esImgDoc
                    ? "Se analizará el documento del doctor en BD."
                    : (iaDocBase64 ? "El doc. no es una imagen." : "No hay documento del doctor en BD.");

                // Reset estado
                iaImagenBlob = null;
                document.getElementById("iaMiniPreview").classList.add("d-none");
                document.getElementById("iaPastePreview").classList.add("d-none");
                document.getElementById("iaBtnAnalizarPaste").classList.add("d-none");

                try {
                    const mdIADom = document.getElementById("mdIA");
                    // Limpiar estado previo completamente
                    const existInst = bootstrap.Modal.getInstance(mdIADom);
                    if(existInst) { existInst.dispose(); }
                    // Limpiar clases y estilos residuales del DOM
                    mdIADom.classList.remove("show");
                    mdIADom.style.display = "";
                    mdIADom.removeAttribute("aria-modal");
                    mdIADom.removeAttribute("role");
                    // Limpiar backdrops y body
                    document.querySelectorAll(".modal-backdrop").forEach(b => b.remove());
                    document.body.classList.remove("modal-open");
                    document.body.style.overflow = "";
                    document.body.style.paddingRight = "";
                    // Abrir fresco
                    setTimeout(function(){
                        new bootstrap.Modal(mdIADom, {backdrop: true, keyboard: true}).show();
                        console.log("mdIA.show() llamado OK (fresh)");
                    }, 50);
                } catch(err) {
                    console.error("Error abriendo mdIA:", err);
                }
            }

            function iaAnalizarBlob(blob, cb) {
                if (!iaIdCita) { Swal.fire("Aviso","No hay cita seleccionada.","warning"); return; }
                Swal.fire({title:"Analizando con IA...",allowOutsideClick:false,didOpen:()=>Swal.showLoading()});
                const servicio = document.getElementById("iaServicioIA").value || "dental";
                const razon = document.getElementById("iaIndicaciones")?.value || "";
                const contexto = razon
                    ? `El paciente describe: "${razon}". Analiza la imagen.`
                    : "Analiza esta imagen clínica y describe los hallazgos.";
                const form = new FormData();
                form.append("idCita", iaIdCita);
                form.append("imagen", blob, "imagen.jpg");
                form.append("servicio", servicio);
                form.append("contexto", contexto);
                fetch("/Citas/AnalizarImagenIA", {method:"POST", body:form})
                .then(r => r.json()).then(res => {
                    Swal.close();
                    if (res.ok) {
                        document.getElementById("iaTextoIA").innerText = res.diagnostico;
                        document.getElementById("iaResultadoIA").classList.remove("d-none");
                        // También actualizar el modal principal
                        const dhcTxt = document.getElementById("dhcTextoIA");
                        const dhcRes = document.getElementById("dhcResultadoIA");
                        if(dhcTxt) dhcTxt.innerText = res.diagnostico;
                        if(dhcRes) dhcRes.classList.remove("d-none");
                        // Si indicaciones vacías, prellenar
                        const ind = document.getElementById("iaIndicaciones");
                        if(ind && ind.value.trim() === "") ind.value = res.diagnostico;
                        if(cb) cb();
                    } else {
                        Swal.fire("Error IA", res.msg || "Error", "error");
                        if(cb) cb();
                    }
                }).catch(() => { Swal.fire("Error","Fallo de comunicación.","error"); if(cb)cb(); });
            }

            document.addEventListener("DOMContentLoaded", function() {

                // Guardar indicaciones desde submodal
                document.getElementById("iaBtnGuardarIndicaciones").addEventListener("click", function() {
                    if (!iaIdCita) { Swal.fire("Aviso","No hay cita.","warning"); return; }
                    const texto = document.getElementById("iaIndicaciones").value.trim();
                    fetch(`/Citas/GuardarIndicaciones?idCita=${iaIdCita}`, {
                        method:"POST",
                        headers:{"Content-Type":"application/json"},
                        body: JSON.stringify({indicaciones: texto})
                    }).then(r => r.json()).then(res => {
                        if(res.ok) {
                            // Sincronizar con modal principal
                            const mainInd = document.getElementById("citaIndicaciones");
                            if(mainInd) mainInd.value = texto;
                            Swal.fire({title:"Guardado",icon:"success",timer:1200,showConfirmButton:false});
                        } else {
                            Swal.fire("Error", res.msg || "Error al guardar","error");
                        }
                    }).catch(()=>Swal.fire("Error","Fallo de comunicación.","error"));
                });

                // Botón usar diagnóstico en indicaciones
                document.getElementById("iaBtnUsarDiagnostico").addEventListener("click", function() {
                    const diag = document.getElementById("iaTextoIA").innerText;
                    const ind = document.getElementById("iaIndicaciones");
                    if(diag && ind) ind.value = diag;
                });

                // Cámara desde submodal — reutiliza el fullscreen existente
                document.getElementById("iaBtnAbrirCamara").addEventListener("click", function() {
                    // Marcar que el fullscreen pertenece al submodal IA
                    window._fsModoIA = true;
                    dhcFsAbrir();
                });

                // Pegar captura
                const iaPa = document.getElementById("iaPasteArea");
                iaPa.addEventListener("click", () => iaPa.focus());
                iaPa.addEventListener("paste", function(e) {
                    for (const item of (e.clipboardData?.items || [])) {
                        if (item.type.startsWith("image/")) {
                            const blob = item.getAsFile();
                            iaImagenBlob = blob;
                            document.getElementById("iaPasteImg").src = URL.createObjectURL(blob);
                            document.getElementById("iaPastePreview").classList.remove("d-none");
                            document.getElementById("iaBtnAnalizarPaste").classList.remove("d-none");
                            iaPa.querySelector("span").textContent = "✔ Pegada. Pulse Analizar.";
                            break;
                        }
                    }
                });
                document.getElementById("iaBtnAnalizarPaste").addEventListener("click", () => {
                    if(iaImagenBlob) iaAnalizarBlob(iaImagenBlob);
                });

                // Fichero
                document.getElementById("iaBtnAnalizarFichero").addEventListener("click", function() {
                    const file = document.getElementById("iaFileIA").files[0];
                    if(!file){Swal.fire("Aviso","Seleccione un fichero.","warning");return;}
                    if(!file.type.startsWith("image/")){Swal.fire("Aviso","Solo imágenes.","warning");return;}
                    iaAnalizarBlob(file);
                });

                // BD Paciente
                document.getElementById("iaBtnAnalizarBDPac").addEventListener("click", function() {
                    if(!iaPacBase64) return;
                    const b=atob(iaPacBase64), a=new Uint8Array(b.length);
                    for(let i=0;i<b.length;i++) a[i]=b.charCodeAt(i);
                    iaAnalizarBlob(new Blob([a],{type:iaPacContentType||"image/jpeg"}));
                });

                // BD Doctor
                document.getElementById("iaBtnAnalizarBDDoc").addEventListener("click", function() {
                    if(!iaDocBase64) return;
                    const b=atob(iaDocBase64), a=new Uint8Array(b.length);
                    for(let i=0;i<b.length;i++) a[i]=b.charCodeAt(i);
                    iaAnalizarBlob(new Blob([a],{type:iaDocContentType||"image/jpeg"}));
                });

                // Descargar doc doctor
                document.getElementById("iaBtnDescDocDoctor").addEventListener("click", async function() {
                    if(!iaIdCita) return;
                    const url = `/Citas/DescargarDocumentoDoctor?idCita=${iaIdCita}`;
                    const r = await fetch(url,{method:"GET"});
                    if(!r.ok){Swal.fire("Info","No hay documento.","info");return;}
                    const blob = await r.blob();
                    const cd = r.headers.get("content-disposition")||"";
                    const m = /filename\*=UTF-8''([^;]+)|filename="?([^"]+)"?/i.exec(cd);
                    const filename = m ? decodeURIComponent(m[1]||m[2]||"") : `doc_doctor_${iaIdCita}`;
                    const urlObj = URL.createObjectURL(blob);
                    const a = document.createElement("a");
                    a.href=urlObj; a.download=filename;
                    document.body.appendChild(a); a.click(); a.remove();
                    setTimeout(()=>URL.revokeObjectURL(urlObj),1000);
                });

            }); // fin DOMContentLoaded submodal IA

            function dhcFsAbrir(){
                // Si venimos del submodal IA, cerrarlo temporalmente
                if(window._fsModoIA) {
                    const mdIAEl = document.getElementById("mdIA");
                    if(mdIAEl) bootstrap.Modal.getInstance(mdIAEl)?.hide();
                }
                document.getElementById("dhcFullscreen").style.display="flex";
                document.body.style.overflow="hidden";
                document.getElementById("dhcFsStreamDiv").style.display="flex";
                document.getElementById("dhcFsCropperDiv").style.display="none";
                document.getElementById("dhcFsControles").style.display="none";
                document.getElementById("dhcFsResultado").style.display="none";
                document.getElementById("dhcFsBtnVerResultados").classList.add("d-none");
                dhcFsAbrirStream();
            }
            function dhcFsCerrar(){
                dhcFsCerrarStream();
                if(dhcFsCropper){dhcFsCropper.destroy();dhcFsCropper=null;}
                document.getElementById("dhcFullscreen").style.display="none";
                document.body.style.overflow="";
            }
            function dhcFsAbrirStream(){
                dhcFsCerrarStream();
                navigator.mediaDevices.getUserMedia({video:{facingMode:dhcFsFacingMode,width:{ideal:1280},height:{ideal:720}}})
                .then(s=>{dhcFsStream=s;document.getElementById("dhcFsVideo").srcObject=s;})
                .catch(e=>Swal.fire("Error","No se pudo acceder a la cámara: "+e.message,"error"));
            }
            function dhcFsCerrarStream(){
                if(dhcFsStream){dhcFsStream.getTracks().forEach(t=>t.stop());dhcFsStream=null;}
            }
        </script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
        /* cambio txtfecha fin */
}

