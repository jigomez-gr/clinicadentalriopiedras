@using ClinicaEntidades
@model TelegramCitaTemp
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Cita</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        .star {
            font-size: 2.5rem;
            cursor: pointer;
            color: #ccc;
        }

            .star.selected {
                color: #ffc107;
            }

        .preview-img {
            max-height: 200px;
            object-fit: contain;
            display: block;
            margin: 10px auto;
        }
    </style>
</head>
<body class="bg-light p-3">
    <div class="card shadow mx-auto" style="max-width: 480px;">
        <div class="card-header bg-primary text-white text-center">
            <h5 class="mb-0">✨ Corregir Datos de Cita</h5>
        </div>
        <div class="card-body">

            <!-- Guardamos el ChatId en un campo oculto -->
            <input type="hidden" id="chatId" value="@Model.ChatId" />

            <div class="mb-3">
                <label class="form-label fw-bold">📝 Notas / Motivo:</label>
                <textarea id="txtNotas" class="form-control">@Model.RazonCitaUsr</textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">📝 Opinion  / Doctor y Clínica :</label>       
                <textarea id="txtOpinionDoctorYClinica" class="form-control">@Model.OpinionDoctorYClinica</textarea>
            </div>

            <div class="mb-3 text-center">
                <label class="form-label fw-bold d-block">⭐ Valoración:</label>
                <div id="starContainer">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="star @(i <= (Model.ValDoctorCita ?? 3) ? "selected" : "")" data-value="@i">
                            @(i <= (Model.ValDoctorCita ?? 3) ? "★" : "☆")
                        </span>
                    }
                </div>
                <input type="hidden" id="valDoctorCita" value="@(Model.ValDoctorCita ?? 3)">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">✅ Confirmación:</label>
                <select id="selConfirmada" class="form-select">
                    <option value="S" selected="@(Model.CitaConfirmada == "S")">Confirmada</option>
                    <option value="N" selected="@(Model.CitaConfirmada == "N")">Pendiente</option>
                </select>
            </div>

            <!-- VISTA PREVIA DE IMAGEN 📸 -->
            <div class="text-center">
                <label class="form-label fw-bold">📎 Imagen adjunta:</label>
                @if (Model.DocumentoCitaUsr != null)
                {
                    <img src="data:@Model.ContentType;base64,@Convert.ToBase64String(Model.DocumentoCitaUsr)" class="preview-img img-thumbnail" />
                }
                else
                {
                    <img src="" class="preview-img img-thumbnail" style="display:none;" />
                }
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">📁 Cambiar archivo:</label>
                <input type="file" id="fileInput" class="form-control" accept="image/*">
            </div>

            <button type="button" id="btnGuardar" class="btn btn-success w-100 fw-bold">💾 GUARDAR CAMBIOS</button>
        </div>
    </div>

    <script>
        $(document).ready(function() {
            // 1. Refrescar imagen al seleccionar nuevo archivo 🖼️
            $("#fileInput").change(function() {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $(".preview-img").attr("src", e.target.result).show();
                    };
                    reader.readAsDataURL(file);
                }
            });

            // 2. Manejo de estrellas ⭐
            $(".star").click(function() {
                const val = $(this).data("value");
                $("#valDoctorCita").val(val);
                $(".star").each(function(i) {
                    $(this).text(i < val ? "★" : "☆").toggleClass("selected", i < val);
                });
            });

            // 3. Guardar cambios 💾
            $("#btnGuardar").click(function() {
                const chatId = $("#chatId").val();
                if (!chatId) {
                    alert("Error: No se detectó el ChatId.");
                    return;
                }

                const btn = $(this);
                btn.prop("disabled", true).text("Guardando...");

                const file = document.getElementById('fileInput').files[0];
                const enviar = (base64) => {
                    const payload = {
                        ChatId: chatId,
                        Notas: $("#txtNotas").val(),
                        OpinionDoctorYClinica: $("#txtOpinionDoctorYClinica").val(),
                        ValDoctorCita: parseInt($("#valDoctorCita").val()),
                        CitaConfirmada: $("#selConfirmada").val(),
                        ImagenBase64: base64
                    };

                    $.ajax({
                        url: '/Citas/GuardarCambiosTempAltas',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(payload),
                        success: (r) => {
                            if(r.success) {
                                alert("¡Éxito!");
                                window.close();
                            } else {
                                alert("Error al guardar");
                                btn.prop("disabled", false).text("💾 GUARDAR CAMBIOS");
                            }
                        },
                        error: () => {
                            alert("Error de red");
                            btn.prop("disabled", false).text("💾 GUARDAR CAMBIOS");
                        }
                    });
                };

                if (file) {
                    const reader = new FileReader();
                    reader.onload = (e) => enviar(e.target.result);
                    reader.readAsDataURL(file);
                } else {
                    enviar(null);
                }
            });
        });
    </script>
</body>
</html>