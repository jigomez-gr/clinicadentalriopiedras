@using ClinicaEntidades
@model TelegramCitaTemp
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Corregir Cita</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body {
            background-color: #f8f9fa;
            padding: 15px;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .btn-save {
            background-color: #2481cc;
            color: white;
            font-weight: bold;
            border-radius: 10px;
            padding: 12px;
        }
    </style>
</head>
<body>
    <div class="card p-3">
        <h5 class="text-center mb-3">Modificar Cita</h5>

        <div class="alert alert-info py-2" style="font-size: 0.85em;">
            @* Adaptación a las propiedades de TelegramCitaTemp *@
            <strong>Doctor:</strong> @Model.NombreYValDoctor<br />
            <strong>Cita:</strong> @Model.Fecha a las @Model.Hora
        </div>

        <input type="hidden" id="chatId" value="@Model.ChatId" />

        <div class="mb-3">
            <label class="form-label fw-bold">Mis Notas:</label>
            @* Usamos RazonCitaUsr que es donde vienen las notas de la DB *@
            <textarea id="notasInput" class="form-control" rows="3">@Model.RazonCitaUsr</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Cambiar Foto:</label>
            <input type="file" id="fileInput" class="form-control form-control-sm" accept="image/*">
            <div class="mt-2 text-center">
                @* Si ya existe un documento, lo mostramos; si no, permanece oculto *@
                <img src="@(Model.DocumentoCitaUsr == null ? "#" : "data:image/jpeg;base64," + Convert.ToBase64String(Model.DocumentoCitaUsr))"
                     id="imgPreview"
                     class="img-fluid rounded border @(Model.DocumentoCitaUsr == null ? "d-none" : "")"
                     style="max-height: 150px;">
            </div>
        </div>

        <button type="button" id="btnGuardar" class="btn btn-save w-100">
            💾 GUARDAR Y VOLVER AL CHAT
        </button>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();

        $(document).ready(function() {
            // Previsualización de imagen
            $("#fileInput").change(function() {
                const file = this.files[0];
                if (file) {
                    let reader = new FileReader();
                    reader.onload = function(e) {
                        $("#imgPreview").attr("src", e.target.result).removeClass("d-none");
                    }
                    reader.readAsDataURL(file);
                }
            });

            $("#btnGuardar").click(function() {
                const btn = $(this);
                btn.prop("disabled", true).text("Guardando...");

                const enviarDatos = (base64) => {
                    const payload = {
                        ChatId: $("#chatId").val(),
                        Notas: $("#notasInput").val(), // Esto mapea a la propiedad 'ayudante' que añadimos a la clase
                        ImagenBase64: base64           // Esto mapea a la otra propiedad 'ayudante'
                    };

                    $.ajax({
                        // CAMBIO CLAVE: Ahora apunta al método aislado de Altas
                        url: '/Citas/GuardarCambiosTempAltas',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(payload),
                        success: function(r) {
                            if(r.success) {
                                tg.close();
                            } else {
                                alert("Error: " + (r.mensaje || "No se pudo guardar"));
                                btn.prop("disabled", false).text("💾 GUARDAR Y VOLVER");
                            }
                        },
                        error: function() {
                            alert("Error crítico al guardar");
                            btn.prop("disabled", false).text("💾 GUARDAR Y VOLVER");
                        }
                    });
                };

                const file = document.getElementById('fileInput').files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = (e) => enviarDatos(e.target.result);
                    reader.readAsDataURL(file);
                } else {
                    enviarDatos(null);
                }
            });
        });
    </script>
</body>
</html>