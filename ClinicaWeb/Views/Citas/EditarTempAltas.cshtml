@using ClinicaEntidades
@model TelegramCitaTemp
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Cita</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        .star {
            font-size: 2.5rem;
            cursor: pointer;
            color: #ccc;
            transition: color 0.2s;
        }

            .star.selected {
                color: #ffc107;
            }

        .preview-img {
            max-height: 180px;
            object-fit: contain;
            border: 2px solid #dee2e6;
        }
    </style>
</head>
<body class="bg-light p-3">
    <div class="card shadow mx-auto" style="max-width: 480px;">
        <div class="card-header bg-primary text-white text-center">
            <h5 class="mb-0">✨ Corregir Datos de Cita</h5>
        </div>
        <div class="card-body">
            <!-- Información de Referencia -->
            <div class="mb-3 p-2 bg-info bg-opacity-10 border rounded small">
                <strong>🩺 Doctor:</strong> @Model.NombreYValDoctor <br />
                <strong>📅 Fecha:</strong> @Model.Fecha a las @Model.Hora
            </div>

            <!-- Campo CRÍTICO: ChatId 🆔 -->
            <input type="hidden" id="chatId" value="@Model.ChatId" />

            <!-- Motivo / Notas -->
            <div class="mb-3">
                <label class="form-label fw-bold">📝 Motivo de la consulta:</label>
                <textarea id="txtNotas" class="form-control" rows="2">@Model.RazonCitaUsr</textarea>
            </div>

            <!-- Valoración Estrellas -->
            <div class="mb-3 text-center">
                <label class="form-label fw-bold d-block">⭐ Tu valoración:</label>
                <div id="starContainer">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="star @(i <= (Model.ValDoctorCita ?? 3) ? "selected" : "")" data-value="@i">
                            @(i <= (Model.ValDoctorCita ?? 3) ? "★" : "☆")
                        </span>
                    }
                </div>
                <input type="hidden" id="valDoctorCita" value="@(Model.ValDoctorCita ?? 3)">
            </div>

            <!-- Opinión -->
            <div class="mb-3">
                <label class="form-label fw-bold">💬 Opinión adicional:</label>
                <textarea id="txtOpinion" class="form-control" rows="2">@Model.OpinionDoctorYClinica</textarea>
            </div>

            <!-- Confirmación ✅ -->
            <div class="mb-3">
                <label class="form-label fw-bold">✅ ¿Confirmas la asistencia?</label>
                <select id="selConfirmada" class="form-select">
                    <option value="S" selected="@(Model.CitaConfirmada == "S")">Sí, confirmada</option>
                    <option value="N" selected="@(Model.CitaConfirmada == "N" || string.IsNullOrEmpty(Model.CitaConfirmada))">No, pendiente</option>
                </select>
            </div>

            <!-- Vista Previa de Imagen Actual -->
            @if (Model.DocumentoCitaUsr != null && Model.DocumentoCitaUsr.Length > 0)
            {
                <div class="mb-3 text-center">
                    <label class="form-label fw-bold d-block text-muted">📎 Archivo adjunto actual:</label>
                    <img src="data:@Model.ContentType;base64,@Convert.ToBase64String(Model.DocumentoCitaUsr)" class="img-fluid rounded preview-img" />
                </div>
            }

            <!-- Subida de Nuevo Archivo -->
            <div class="mb-4">
                <label class="form-label fw-bold">📁 Cambiar foto/documento:</label>
                <input type="file" id="fileInput" class="form-control" accept="image/*">
            </div>

            <button type="button" id="btnGuardar" class="btn btn-success w-100 fw-bold shadow">
                💾 GUARDAR CAMBIOS
            </button>
        </div>
    </div>

    <script>
        $(document).ready(function() {
            // Manejo de Estrellas ⭐
            $(".star").click(function() {
                const val = $(this).data("value");
                $("#valDoctorCita").val(val);
                $(".star").each(function(i) {
                    $(this).text(i < val ? "★" : "☆").toggleClass("selected", i < val);
                });
            });

            // Acción de Guardar 💾
            $("#btnGuardar").click(function() {
                const btn = $(this);
                const chatIdVal = $("#chatId").val();

                // Validación preventiva
                if (!chatIdVal) {
                    alert("Error: No se detectó el ChatId.");
                    return;
                }

                btn.prop("disabled", true).text("🚀 Enviando...");
                const file = document.getElementById('fileInput').files[0];

                const enviar = (base64) => {
                    const payload = {
                        ChatId: chatIdVal,
                        Notas: $("#txtNotas").val(), // Mapea a la propiedad 'Notas' de tu clase
                        ValDoctorCita: parseInt($("#valDoctorCita").val()),
                        OpinionDoctorYClinica: $("#txtOpinion").val(),
                        CitaConfirmada: $("#selConfirmada").val(),
                        ImagenBase64: base64
                    };

                    console.log("Payload a enviar:", payload); // Depuración en consola 🔍

                    $.ajax({
                        url: '/Citas/GuardarCambiosTempAltas',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(payload),
                        success: (r) => {
                            if(r.success) {
                                alert("✅ ¡Datos actualizados!");
                                window.close();
                            } else {
                                alert("❌ Error: " + (r.mensaje || "El servidor rechazó los datos."));
                                btn.prop("disabled", false).text("💾 GUARDAR CAMBIOS");
                            }
                        },
                        error: (xhr) => {
                            console.error("Error servidor:", xhr.responseText);
                            alert("📡 Error de comunicación con el servidor.");
                            btn.prop("disabled", false).text("💾 GUARDAR CAMBIOS");
                        }
                    });
                };

                if (file) {
                    const reader = new FileReader();
                    reader.onload = (e) => enviar(e.target.result);
                    reader.readAsDataURL(file);
                } else {
                    enviar(null);
                }
            });
        });
    </script>
</body>
</html>