@using ClinicaEntidades
@model TelegramCitaTemp
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modificar Alta</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        .star {
            font-size: 2.5rem;
            cursor: pointer;
            color: #ccc;
            transition: color 0.2s;
        }

            .star.selected {
                color: #ffc107;
            }

            .star:hover {
                color: #ffdb58;
            }

        .preview-img {
            max-height: 200px;
            object-fit: contain;
        }
    </style>
</head>
<body class="bg-light p-4">
    <div class="card shadow mx-auto" style="max-width: 500px;">
        <div class="card-header bg-primary text-white text-center">
            <h5 class="mb-0">✨ Gestión de Cita Temporal</h5>
        </div>
        <div class="card-body">
            <!-- Datos de solo lectura -->
            <div class="mb-3 p-2 bg-warning bg-opacity-10 border rounded small">
                <strong>🩺 Doctor:</strong> @Model.NombreYValDoctor <br />
                <strong>📅 Fecha:</strong> @Model.Fecha a las @Model.Hora
            </div>

            <input type="hidden" id="chatId" value="@Model.ChatId" />

            <!-- Campos Editables -->
            <div class="mb-3">
                <label class="form-label fw-bold">📝 Motivo de la cita:</label>
                <textarea id="razonCitaUsr" class="form-control" rows="2">@Model.RazonCitaUsr</textarea>
            </div>

            <div class="mb-3 text-center">
                <label class="form-label fw-bold d-block">⭐ Valoración del Doctor:</label>
                <div id="starContainer">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="star @(i <= (Model.ValDoctorCita ?? 3) ? "selected" : "")" data-value="@i">
                            @(i <= (Model.ValDoctorCita ?? 3) ? "★" : "☆")
                        </span>
                    }
                </div>
                <input type="hidden" id="valDoctorCita" value="@(Model.ValDoctorCita ?? 3)">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">💬 Opinión:</label>
                <textarea id="opinionDoctor" class="form-control" rows="2">@Model.OpinionDoctorYClinica</textarea>
            </div>

            <!-- VISTA PREVIA DEL ANEXO ACTUAL 📎 -->
            @if (Model.DocumentoCitaUsr != null && Model.DocumentoCitaUsr.Length > 0)
            {
                <div class="mb-3 border rounded p-2 bg-white text-center">
                    <label class="form-label fw-bold d-block text-muted">📄 Archivo actual:</label>
                    @if (Model.ContentType != null && Model.ContentType.Contains("image"))
                    {
                        <img src="data:@Model.ContentType;base64,@Convert.ToBase64String(Model.DocumentoCitaUsr)"
                             class="img-fluid rounded shadow-sm preview-img" />
                    }
                    else
                    {
                        <div class="alert alert-secondary py-1 small">Documento: @Model.ContentType</div>
                    }
                </div>
            }

            <div class="mb-4">
                <label class="form-label fw-bold">📁 Cambiar documento/foto:</label>
                <input type="file" id="fileInput" class="form-control" accept="image/*">
            </div>

            <button type="button" id="btnGuardar" class="btn btn-success w-100 fw-bold">💾 GUARDAR CAMBIOS</button>
        </div>
    </div>

    <script>
        $(document).ready(function() {
            // Estrellas
            $(".star").click(function() {
                const v = $(this).data("value");
                $("#valDoctorCita").val(v);
                $(".star").each(function(i) {
                    $(this).text(i < v ? "★" : "☆").toggleClass("selected", i < v);
                });
            });

            // Guardar
            $("#btnGuardar").click(function() {
                const btn = $(this);
                btn.prop("disabled", true).text("Enviando...");
                const file = document.getElementById('fileInput').files[0];

                const enviarForm = (base64) => {
                    const payload = {
                        ChatId: $("#chatId").val(),
                        RazonCitaUsr: $("#razonCitaUsr").val(),
                        ValDoctorCita: parseInt($("#valDoctorCita").val()),
                        CitaConfirmada: "S", // Forzamos S al guardar
                        OpinionDoctorYClinica: $("#opinionDoctor").val(),
                        ImagenBase64: base64
                    };

                    $.ajax({
                        url: '/Citas/GuardarCambiosTempAltas',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(payload),
                        success: (r) => {
                            if(r.success) {
                                alert("✅ ¡Listo! Datos actualizados.");
                                window.close();
                            } else {
                                alert("❌ Error: " + r.mensaje);
                                btn.prop("disabled", false).text("💾 GUARDAR CAMBIOS");
                            }
                        },
                        error: () => {
                            alert("📡 Error de conexión.");
                            btn.prop("disabled", false).text("💾 GUARDAR CAMBIOS");
                        }
                    });
                };

                if (file) {
                    const reader = new FileReader();
                    reader.onload = (e) => enviarForm(e.target.result);
                    reader.readAsDataURL(file);
                } else {
                    enviarForm(null);
                }
            });
        });
    </script>
</body>
</html>