@{
    ViewData["Title"] = "Reenviar Foto / Documentos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <style>
        .acciones-container {
            display: flex;
            gap: 4px;
        }

        .btn-circle {
            width: 32px;
            height: 32px;
            padding: 0;
            border-radius: 50%;
            text-align: center;
            font-size: 14px;
            line-height: 32px;
            display: inline-block;
            vertical-align: middle;
        }

        #tbData {
            border-collapse: collapse !important;
        }

        table.dataTable td, table.dataTable th {
            white-space: normal !important;
        }

        .cita-modal-compact .modal-body {
            padding: .75rem;
        }

        .doc-box {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: .375rem;
            padding: .5rem .75rem;
        }
        /* Cropper */
        #rfCropperContainer {
            max-height: 300px;
            background: #000;
            border-radius: 8px;
            overflow: hidden;
        }

        #rfImgCropper {
            max-width: 100%;
            display: block;
        }

        .cropper-view-box, .cropper-face {
            border-radius: 0;
        }
    </style>
}

<h2 class="mt-4 mb-4 d-flex align-items-center">
    <span>Reenviar Foto / Documentos</span>
    <button type="button" class="btn btn-sm ms-auto" style="background-color:#ff8c00;color:#fff;"
            onclick="openHelpVideo('ReenviarFoto.mp4')" data-bs-toggle="tooltip" title="Ayuda">
        <i class="fa fa-circle-question me-1"></i> Ayuda
    </button>
</h2>

<div class="row">
    <div class="col-12">
        <div class="card mb-4">
            <div class="card-header"><i class="fas fa-file-upload me-1"></i> Citas pendientes</div>
            <div class="card-body">
                <div class="alert alert-info small py-2 mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Puede actualizar el motivo y el documento adjunto de sus citas pendientes.
                </div>
                <div class="table-responsive">
                    <table class="display table table-striped table-bordered table-hover nowrap"
                           id="tbData" cellspacing="0" style="width:100%">
                        <thead>
                            <tr>
                                <th>Acciones</th>
                                <th>Nº Cita</th>
                                <th>Fecha Cita</th>
                                <th>Hora Cita</th>
                                <th>Tipo</th>
                                <th>Especialidad</th>
                                <th>Doctor</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===================== MODAL ===================== -->
<div class="modal fade" id="mdReenviarFoto" data-bs-backdrop="static" data-bs-keyboard="false"
     tabindex="-1" aria-labelledby="mdReenviarFotoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content cita-modal-compact">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="mdReenviarFotoLabel">
                    <i class="fas fa-file-upload me-2"></i>Reenviar Foto / Documentos
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- Datos solo lectura -->
                <div class="row g-2 mb-2">
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-bold">Nº Cita</label>
                        <input type="text" class="form-control" id="rfIdCita" disabled />
                    </div>
                    <div class="col-12 col-md-5">
                        <label class="form-label fw-bold">Doctor</label>
                        <input type="text" class="form-control" id="rfDoctor" disabled />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold">Especialidad</label>
                        <input type="text" class="form-control" id="rfEspecialidad" disabled />
                    </div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold">Fecha Cita</label>
                        <input type="text" class="form-control" id="rfFechaCita" disabled />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold">Hora Cita</label>
                        <input type="text" class="form-control" id="rfHoraCita" disabled />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold">Tipo de Cita</label>
                        <input type="text" class="form-control" id="rfTipoCita" disabled />
                    </div>
                </div>

                <hr />

                <!-- Motivo -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Motivo de la cita</label>
                    <textarea class="form-control" id="rfRazonCitaUsr" rows="3"
                              placeholder="Describa el motivo de la cita..."></textarea>
                </div>

                <!-- Documento paciente actual -->
                <div class="mb-2 doc-box">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="fw-bold small">Documento actual del paciente:</span>
                        <button type="button" id="rfBtnVerDocPaciente" class="btn btn-outline-secondary btn-sm" disabled>
                            <i class="fas fa-file me-1"></i> Ver documento actual
                        </button>
                        <small id="rfLblSinDocPaciente" class="text-muted">No hay documento.</small>
                        <small id="rfLblHayDocPaciente" class="text-success d-none">
                            <i class="fas fa-check me-1"></i>Hay un documento adjunto.
                        </small>
                    </div>
                </div>

                <!-- Nuevo documento -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Actualizar / reenviar documento del paciente</label>
                    <input type="file" class="form-control" id="rfFileDocPaciente"
                           accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                    <small class="form-text text-muted">PDF, imagen o documento (informes, radiografías, etc.)</small>
                </div>

                <hr />

                <!-- ── Análisis IA ──────────────────────────────────────── -->
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        <i class="fas fa-robot me-1 text-success"></i>Análisis IA
                    </label>

                    <!-- Selector servicio -->
                    <div class="mb-2">
                        <select class="form-select form-select-sm" id="rfServicioIA" style="max-width:220px;">
                            <option value="dental">🦷 Dental (boca/encías)</option>
                            <option value="rx">🩻 Radiografía dental</option>
                            <option value="derma">🔬 Dermatología</option>
                            <option value="belleza">✨ Estética</option>
                            <option value="general">🏥 General</option>
                        </select>
                    </div>

                    <!-- Pestañas de fuente de imagen -->
                    <ul class="nav nav-tabs nav-sm mb-2" id="rfTabsIA">
                        <li class="nav-item">
                            <button class="nav-link active small" id="rfTabCamara-tab"
                                    data-bs-toggle="tab" data-bs-target="#rfTabCamara">
                                <i class="fas fa-camera me-1"></i>Cámara
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link small" id="rfTabFichero-tab"
                                    data-bs-toggle="tab" data-bs-target="#rfTabFichero">
                                <i class="fas fa-file-image me-1"></i>Fichero subido
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link small" id="rfTabBD-tab"
                                    data-bs-toggle="tab" data-bs-target="#rfTabBD">
                                <i class="fas fa-database me-1"></i>Doc. en BD
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">

                        <!-- Tab 1: Cámara con Cropper -->
                        <div class="tab-pane fade show active" id="rfTabCamara">
                            <div class="d-flex gap-2 flex-wrap mb-2">
                                <button type="button" class="btn btn-success btn-sm" id="rfBtnAbrirCamara">
                                    <i class="fas fa-camera me-1"></i>Tomar foto
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm d-none" id="rfBtnCerrarCamara">
                                    Cancelar cámara
                                </button>
                            </div>
                            <!-- Stream vídeo -->
                            <div id="rfCamaraStreamContainer" class="d-none mb-2 position-relative">
                                <video id="rfVideo" autoplay playsinline
                                       style="width:100%;max-height:280px;border-radius:8px;background:#000;"></video>
                                <button type="button" id="rfBtnVoltear"
                                        class="btn btn-dark btn-sm position-absolute"
                                        style="top:8px;right:8px;opacity:0.8;">
                                    <i class="fas fa-sync-alt"></i> Voltear
                                </button>
                                <div class="mt-2">
                                    <button type="button" class="btn btn-primary btn-sm" id="rfBtnCapturar">
                                        <i class="fas fa-camera me-1"></i>Capturar
                                    </button>
                                </div>
                            </div>
                            <!-- Cropper -->
                            <div id="rfCropperWrapper" class="d-none mb-2">
                                <div id="rfCropperContainer">
                                    <img id="rfImgCropper" src="" alt="Recortar" />
                                </div>
                                <div class="d-flex gap-2 mt-2 flex-wrap">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="rfBtnZoomIn">
                                        <i class="fas fa-search-plus"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="rfBtnZoomOut">
                                        <i class="fas fa-search-minus"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="rfBtnResetCrop">
                                        <i class="fas fa-undo"></i> Reset
                                    </button>
                                    <button type="button" class="btn btn-success btn-sm ms-auto" id="rfBtnAnalizarCamara">
                                        <i class="fas fa-microscope me-1"></i>Analizar recorte con IA
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Tab 2: Fichero recién subido -->
                        <div class="tab-pane fade" id="rfTabFichero">
                            <p class="small text-muted mb-2">
                                Seleccione primero un fichero de imagen en el campo de documento de arriba,
                                luego pulse analizar.
                            </p>
                            <button type="button" class="btn btn-success btn-sm" id="rfBtnAnalizarFichero">
                                <i class="fas fa-microscope me-1"></i>Analizar fichero adjunto con IA
                            </button>
                        </div>

                        <!-- Tab 3: Documento en BD -->
                        <div class="tab-pane fade" id="rfTabBD">
                            <p class="small text-muted mb-2" id="rfLblBDInfo">
                                Se analizará el documento que ya está guardado en la base de datos para esta cita.
                            </p>
                            <button type="button" class="btn btn-success btn-sm" id="rfBtnAnalizarBD" disabled>
                                <i class="fas fa-database me-1"></i>Analizar documento en BD con IA
                            </button>
                        </div>

                    </div>

                    <!-- Resultado IA -->
                    <div id="rfResultadoIA" class="d-none mt-3">
                        <div class="alert alert-success small py-2 mb-0" id="rfTextoIA"
                             style="white-space: pre-line;"></div>
                    </div>
                </div>

                <hr />

                <!-- Documento doctor -->
                <div class="mb-2 doc-box">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="fw-bold small">Documento del doctor:</span>
                        <button type="button" id="rfBtnVerDocDoctor" class="btn btn-outline-primary btn-sm" disabled>
                            <i class="fas fa-file-medical me-1"></i> Ver documento doctor
                        </button>
                        <small id="rfLblSinDocDoctor" class="text-muted">No hay documento del doctor.</small>
                        <small id="rfLblHayDocDoctor" class="text-success d-none">
                            <i class="fas fa-check me-1"></i>Hay un documento del doctor.
                        </small>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary px-4" id="rfBtnGuardar">
                    <i class="fas fa-save me-1"></i>Guardar cambios
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script>
        (function () {
            "use strict";
            window.openHelpVideo = function (fileName) {
                const w = 900, h = 520;
                const left = Math.max(0, (screen.width - w) / 2);
                const top  = Math.max(0, (screen.height - h) / 2);
                window.open("/helps/" + encodeURIComponent(fileName), "helpVideo",
                    `width=${w},height=${h},left=${left},top=${top},resizable=yes`);
            };
        })();

        let tablaData;
        let idEditar = 0;
        let docPacienteBase64 = null, docPacienteContentType = null;
        let docDoctorBase64   = null, docDoctorContentType   = null;
        let streamCamara      = null;
        let facingMode        = "environment";
        let cropperInstance   = null;
        let imagenFinalBlob   = null;  // imagen a guardar como documentocitausr
        const controlador     = "Citas";

        document.addEventListener("DOMContentLoaded", function () {

            // ── DataTable ────────────────────────────────────────────────
            tablaData = $('#tbData').DataTable({
                processing: true,
                serverSide: false,
                ajax: { url: `/${controlador}/ListaCitasPendiente`, type: "GET", datatype: "json" },
                columns: [
                    {
                        data: null,
                        render: function (data, type, row) {
                            return `<div class="acciones-container">
                                <button class="btn btn-primary btn-circle text-white btn-reenviar" title="Reenviar foto/documentos">
                                    <i class="fas fa-file-upload"></i>
                                </button>
                            </div>`;
                        },
                        orderable: false, width: "60px"
                    },
                    { data: "idCita", width: "80px" },
                    { data: "fechaCita" },
                    { data: "horaCita" },
                    {
                        data: "tipoDeCita",
                        render: function(v) {
                            const map = {
                                P: '<span class="badge bg-primary">Presencial</span>',
                                T: '<span class="badge bg-warning text-dark">Telefónica</span>',
                                V: '<span class="badge bg-info text-dark">Virtual</span>'
                            };
                            return map[v] || v || '';
                        }
                    },
                    { data: "especialidad", render: d => d ? d.nombre : "" },
                    { data: "doctor",       render: d => d ? `${d.nombres} ${d.apellidos}`.trim() : "" }
                ],
                scrollX: true,
                language: { url: "//cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json" }
            });

            // ── Abrir modal ──────────────────────────────────────────────
            $("#tbData tbody").on("click", ".btn-reenviar", function () {
                const data = tablaData.row($(this).closest("tr")).data();
                idEditar = data.idCita;

                $("#rfIdCita").val(data.idCita);
                $("#rfDoctor").val(data.doctor ? `${data.doctor.nombres} ${data.doctor.apellidos}`.trim() : "");
                $("#rfEspecialidad").val(data.especialidad ? data.especialidad.nombre : "");
                $("#rfFechaCita").val(data.fechaCita ?? "");
                $("#rfHoraCita").val(data.horaCita ?? "");

                const tipoMap = { P: "Presencial", T: "Telefónica", V: "Virtual" };
                $("#rfTipoCita").val(tipoMap[data.tipoDeCita] || data.tipoDeCita || "Presencial");

                $("#rfRazonCitaUsr").val(data.razonCitaUsr || "");

                // Diagnóstico IA previo
                if (data.diagnosticoIA) {
                    document.getElementById("rfTextoIA").innerText = data.diagnosticoIA;
                    document.getElementById("rfResultadoIA").classList.remove("d-none");
                } else {
                    document.getElementById("rfTextoIA").innerText = "";
                    document.getElementById("rfResultadoIA").classList.add("d-none");
                }

                // Documento paciente
                docPacienteBase64      = data.documentoCitaUsr ?? null;
                docPacienteContentType = data.contentType ?? "application/octet-stream";
                if (docPacienteBase64) {
                    $("#rfBtnVerDocPaciente").prop("disabled", false);
                    $("#rfLblHayDocPaciente").removeClass("d-none");
                    $("#rfLblSinDocPaciente").addClass("d-none");
                    // Habilitar análisis de BD solo si es imagen
                    const esImagen = (docPacienteContentType || "").startsWith("image/");
                    $("#rfBtnAnalizarBD").prop("disabled", !esImagen);
                    $("#rfLblBDInfo").text(esImagen
                        ? "Se analizará la imagen guardada en la base de datos para esta cita."
                        : "El documento en BD no es una imagen y no puede analizarse con IA.");
                } else {
                    $("#rfBtnVerDocPaciente").prop("disabled", true);
                    $("#rfLblHayDocPaciente").addClass("d-none");
                    $("#rfLblSinDocPaciente").removeClass("d-none");
                    $("#rfBtnAnalizarBD").prop("disabled", true);
                    $("#rfLblBDInfo").text("No hay documento guardado en BD para esta cita.");
                }

                // Documento doctor
                docDoctorBase64      = data.docIndicacionesDoctor ?? null;
                docDoctorContentType = data.contentTypeDoctor ?? "application/octet-stream";
                if (docDoctorBase64) {
                    $("#rfBtnVerDocDoctor").prop("disabled", false);
                    $("#rfLblHayDocDoctor").removeClass("d-none");
                    $("#rfLblSinDocDoctor").addClass("d-none");
                } else {
                    $("#rfBtnVerDocDoctor").prop("disabled", true);
                    $("#rfLblHayDocDoctor").addClass("d-none");
                    $("#rfLblSinDocDoctor").removeClass("d-none");
                }

                // Limpiar cámara/cropper
                resetCamara();
                $("#rfFileDocPaciente").val("");
                imagenFinalBlob = null;

                new bootstrap.Modal(document.getElementById('mdReenviarFoto')).show();
            });

            // Cerrar modal
            document.getElementById("mdReenviarFoto").addEventListener("hidden.bs.modal", function () {
                cerrarStream();
                destroyCropper();
                imagenFinalBlob = null;
            });

            // ── Ver documentos ───────────────────────────────────────────
            $("#rfBtnVerDocPaciente").on("click", function () {
                if (docPacienteBase64) abrirDocumento(docPacienteBase64, docPacienteContentType);
            });
            $("#rfBtnVerDocDoctor").on("click", function () {
                if (docDoctorBase64) abrirDocumento(docDoctorBase64, docDoctorContentType);
            });

            // ── Guardar cambios ──────────────────────────────────────────
            $("#rfBtnGuardar").on("click", function () {
                // Si hay recorte de cámara siempre tiene prioridad sobre el fichero
                if (imagenFinalBlob) {
                    const reader = new FileReader();
                    reader.readAsDataURL(imagenFinalBlob);
                    reader.onload = () => enviarDatos(
                        reader.result.split(',')[1],
                        imagenFinalBlob.type || "image/jpeg"
                    );
                } else {
                    const file = document.getElementById("rfFileDocPaciente").files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.readAsDataURL(file);
                        reader.onload = () => enviarDatos(reader.result.split(',')[1], file.type);
                    } else {
                        enviarDatos(null, null);
                    }
                }
            });

            function enviarDatos(b64, type) {
                Swal.fire({ title: 'Guardando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                fetch(`/${controlador}/ActualizarMotivoPaciente`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        idCita:               idEditar,
                        razonCitaUsr:         $("#rfRazonCitaUsr").val(),
                        documentoBase64:      b64,
                        contentType:          type,
                        valDoctorCita:        null,
                        opinionDoctorYClinica: null,
                        citaConfirmada:       null,
                        fechaConfirmacion:    null
                    })
                })
                .then(r => r.json())
                .then(() => {
                    bootstrap.Modal.getInstance(document.getElementById('mdReenviarFoto'))?.hide();
                    Swal.fire("¡Guardado!", "Los datos se han actualizado correctamente.", "success")
                        .then(() => tablaData.ajax.reload());
                })
                .catch(() => Swal.fire("Error", "Fallo de comunicación con el servidor.", "error"));
            }

            // ── Cámara con Cropper ────────────────────────────────────────
            document.getElementById("rfBtnAbrirCamara").addEventListener("click", function () {
                facingMode = "environment";
                abrirStream();
            });

            document.getElementById("rfBtnVoltear").addEventListener("click", function () {
                facingMode = facingMode === "environment" ? "user" : "environment";
                abrirStream();
            });

            document.getElementById("rfBtnCerrarCamara").addEventListener("click", function () {
                resetCamara();
            });

            document.getElementById("rfBtnCapturar").addEventListener("click", function () {
                const video  = document.getElementById("rfVideo");
                const canvas = document.createElement("canvas");
                canvas.width  = video.videoWidth;
                canvas.height = video.videoHeight;
                canvas.getContext("2d").drawImage(video, 0, 0);
                cerrarStream();
                document.getElementById("rfCamaraStreamContainer").classList.add("d-none");

                // Cargar en Cropper
                const imgCropper = document.getElementById("rfImgCropper");
                imgCropper.src   = canvas.toDataURL("image/jpeg", 0.92);
                document.getElementById("rfCropperWrapper").classList.remove("d-none");

                destroyCropper();
                cropperInstance = new Cropper(imgCropper, {
                    aspectRatio:      NaN,
                    viewMode:         1,
                    autoCropArea:     0.85,
                    responsive:       true,
                    movable:          true,
                    zoomable:         true,
                    cropBoxMovable:   true,
                    cropBoxResizable: true,
                    dragMode:         "move"
                });
            });

            // Controles Cropper
            document.getElementById("rfBtnZoomIn").addEventListener("click",    () => cropperInstance?.zoom(0.1));
            document.getElementById("rfBtnZoomOut").addEventListener("click",   () => cropperInstance?.zoom(-0.1));
            document.getElementById("rfBtnResetCrop").addEventListener("click", () => cropperInstance?.reset());

            // Analizar recorte de cámara
            document.getElementById("rfBtnAnalizarCamara").addEventListener("click", function () {
                if (!cropperInstance) { Swal.fire("Aviso", "Primero capture una foto.", "warning"); return; }
                const canvas = cropperInstance.getCroppedCanvas({
                    maxWidth: 1600, maxHeight: 1600,
                    imageSmoothingEnabled: true, imageSmoothingQuality: "high"
                });
                // Añadir margen 20%
                const w = canvas.width, h = canvas.height;
                const mx = Math.round(w * 0.10), my = Math.round(h * 0.10);
                const fullCanvas = document.createElement("canvas");
                fullCanvas.width  = w + mx * 2;
                fullCanvas.height = h + my * 2;
                fullCanvas.getContext("2d").drawImage(canvas, mx, my);

                fullCanvas.toBlob(function(blob) {
                    imagenFinalBlob = blob;
                    analizarBlob(blob);
                }, "image/jpeg", 0.92);
            });

            // ── Tab Fichero ──────────────────────────────────────────────
            document.getElementById("rfBtnAnalizarFichero").addEventListener("click", function () {
                const file = document.getElementById("rfFileDocPaciente").files[0];
                if (!file) { Swal.fire("Aviso", "Primero seleccione un fichero de imagen.", "warning"); return; }
                if (!file.type.startsWith("image/")) { Swal.fire("Aviso", "Solo se pueden analizar imágenes con IA.", "warning"); return; }
                analizarBlob(file);
            });

            // ── Tab BD ───────────────────────────────────────────────────
            document.getElementById("rfBtnAnalizarBD").addEventListener("click", function () {
                if (!docPacienteBase64) return;
                // Convertir base64 a Blob
                const bin  = atob(docPacienteBase64);
                const arr  = new Uint8Array(bin.length);
                for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
                const blob = new Blob([arr], { type: docPacienteContentType || "image/jpeg" });
                analizarBlob(blob);
            });

            // ── Función común de análisis ────────────────────────────────
            function analizarBlob(blob) {
                if (idEditar <= 0) { Swal.fire("Aviso", "No hay cita seleccionada.", "warning"); return; }

                Swal.fire({
                    title: "Analizando imagen con IA...",
                    text: "Esto puede tardar unos segundos.",
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const servicio  = document.getElementById("rfServicioIA").value || "dental";
                const razon     = document.getElementById("rfRazonCitaUsr").value || "";
                const contexto  = razon
                    ? `El paciente describe: "${razon}". Analiza la imagen teniendo en cuenta este contexto.`
                    : "Analiza esta imagen clínica y describe los hallazgos observables.";

                const form = new FormData();
                form.append("idCita",   idEditar);
                form.append("imagen",   blob, "imagen.jpg");
                form.append("servicio", servicio);
                form.append("contexto", contexto);

                fetch("/Citas/AnalizarImagenIA", { method: "POST", body: form })
                .then(r => r.json())
                .then(res => {
                    Swal.close();
                    if (res.ok) {
                        document.getElementById("rfTextoIA").innerText = res.diagnostico;
                        document.getElementById("rfResultadoIA").classList.remove("d-none");
                    } else {
                        Swal.fire("Error IA", res.msg || "Error desconocido", "error");
                    }
                })
                .catch(() => Swal.fire("Error", "Fallo de comunicación con el servidor.", "error"));
            }

            // ── Helpers cámara ───────────────────────────────────────────
            function abrirStream() {
                cerrarStream();
                document.getElementById("rfCropperWrapper").classList.add("d-none");
                navigator.mediaDevices.getUserMedia({
                    video: { facingMode: facingMode, width: { ideal: 1280 }, height: { ideal: 720 } }
                })
                .then(function(stream) {
                    streamCamara = stream;
                    document.getElementById("rfVideo").srcObject = stream;
                    document.getElementById("rfCamaraStreamContainer").classList.remove("d-none");
                    document.getElementById("rfBtnCerrarCamara").classList.remove("d-none");
                })
                .catch(function(e) {
                    Swal.fire("Error", "No se pudo acceder a la cámara: " + e.message, "error");
                });
            }

            function cerrarStream() {
                if (streamCamara) {
                    streamCamara.getTracks().forEach(t => t.stop());
                    streamCamara = null;
                }
                document.getElementById("rfCamaraStreamContainer").classList.add("d-none");
            }

            function destroyCropper() {
                if (cropperInstance) { cropperInstance.destroy(); cropperInstance = null; }
            }

            function resetCamara() {
                cerrarStream();
                destroyCropper();
                document.getElementById("rfCropperWrapper").classList.add("d-none");
                document.getElementById("rfBtnCerrarCamara").classList.add("d-none");
            }

        }); // fin DOMContentLoaded

        function abrirDocumento(base64, contentType) {
            const bin = atob(base64), arr = new Uint8Array(bin.length);
            for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
            window.open(URL.createObjectURL(new Blob([arr], { type: contentType })), "_blank");
        }
    </script>
}
