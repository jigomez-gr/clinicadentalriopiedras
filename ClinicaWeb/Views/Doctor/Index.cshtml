@* *@
@{
    ViewData["Title"] = "Doctores";
}

@section Styles {
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <style>
        .acciones-container {
            display: flex;
            gap: 4px;
        }

        .btn-circle {
            width: 32px;
            height: 32px;
            padding: 0;
            border-radius: 50%;
            text-align: center;
            font-size: 14px;
            line-height: 32px;
            display: inline-block;
            vertical-align: middle;
        }

        #tbData {
            border-collapse: collapse !important;
        }

        @@media (max-width: 768px) {
            #tbData thead th:first-child, #tbData tbody td:first-child {
                position: sticky;
                left: 0;
                background-color: #f8f9fa !important;
                z-index: 5;
                border-right: 2px solid #dee2e6;
            }
        }

        #ui-datepicker-div {
            z-index: 999999 !important;
        }

        table.dataTable td, table.dataTable th {
            white-space: normal !important;
        }

        .btn-repro-verde {
            color: #198754 !important;
            border: 1px solid #198754 !important;
            background-color: transparent !important;
        }

            .btn-repro-verde:hover {
                background-color: #198754 !important;
                color: white !important;
            }

        .api-item {
            cursor: pointer;
            padding: 8px;
            transition: 0.2s;
            border-bottom: 1px solid #eee;
        }

            .api-item:hover {
                background-color: #f0fdf4;
            }

        
            /* Mejora de contraste en la selección de la API  */
            .api-item.selected {
                background-color: #d1e7dd !important;
                color: #0f5132 !important; /* Texto oscuro para lectura fácil */
                border: 1px solid #0f5132 !important;
                font-weight: bold;
            }
    </style>
}

<div class="row">
    <div class="col-sm-12">
        <div class="card mb-4">
            <div class="card-header d-flex align-items-center">
                <i class="fa-solid fa-user-doctor me-2"></i>
                <span>Lista de Doctores</span>
                <button type="button" class="btn btn-success btn-sm ms-auto" onclick="openHelpVideo('Doctor_Horario.mp4')">
                    <i class="fa fa-circle-question me-1"></i> Ayuda
                </button>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-3">
                        <button class="btn btn-outline-success" id="btnNuevo">Nuevo Doctor</button>
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-sm-12">
                        <div class="table-responsive">
                            <table class="display table table-striped table-bordered table-hover nowrap" id="tbData" style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Acciones</th>
                                        <th>Nro Documento</th>
                                        <th>Nombres</th>
                                        <th>Apellidos</th>
                                        <th>Género</th>
                                        <th>Especialidad</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdData" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Doctor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2">
                    <div class="col-sm-4">
                        <label class="col-form-label small">Nro Documento:</label>
                        <input type="text" class="form-control form-control-sm" id="txtNroDocumento">
                    </div>
                    <div class="col-sm-4">
                        <label class="col-form-label small">Nombres:</label>
                        <input type="text" class="form-control form-control-sm" id="txtNombres">
                    </div>
                    <div class="col-sm-4">
                        <label class="col-form-label small">Apellidos:</label>
                        <input type="text" class="form-control form-control-sm" id="txtApellidos">
                    </div>
                    <div class="col-sm-4">
                        <label class="col-form-label small">Género:</label>
                        <select id="cboGenero" class="form-control form-control-sm"></select>
                    </div>

                   
                    
                    <div class="col-sm-5">
                        <label class="col-form-label small">Fotografía:</label>
                        <input type="file" class="form-control form-control-sm" id="txtFoto" accept="image/*">
                        <a id="btnDescargarFoto" href="#" download="foto_doctor.jpg" class="btn btn-outline-secondary btn-sm mt-2" style="display:none;">
                            <i class="fas fa-download"></i> Descargar Foto
                        </a>
                    </div>
                    <div class="col-sm-4 text-center">
                        <img id="imgFotoPreview" src="" class="img-thumbnail"
                             style="width: 160px; height: 160px; display:none; border: 1px solid #ccc; object-fit: cover;">
                    </div>

                    <div class="col-sm-3">
                        <label class="col-form-label small">Valoración (User):</label>
                        <input type="number" class="form-control form-control-sm" id="txtValoracion" min="1" max="5" step="0.1">
                    </div>
                    <div class="col-sm-3">
                        <label class="col-form-label small">Valoración AI:</label>
                        <input type="number" class="form-control form-control-sm" id="txtValoracionAi" min="1" max="5" step="0.1">
                    </div>
                   
                    <div class="col-sm-12">
                        <label class="col-form-label small">Resumen AI:</label>
                        <textarea class="form-control form-control-sm" id="txtResumenValoracion" rows="3"></textarea>
                    </div>
                    <div class="col-sm-12">
                        <label class="col-form-label small">Biografía:</label>
                        <textarea class="form-control form-control-sm" id="txtBiografia" rows="3"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-outline-success" id="btnCalcom">
                    <i class="fa-solid fa-link me-1"></i> Cal.com
                </button>
                <button type="button" class="btn btn-primary" id="btnGuardar">Guardar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdEspecialidades" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title">Especialidades: <span id="lblDoctorEsp" class="badge bg-primary"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <select id="cboEspecialidadMultiple" class="form-select form-select-sm"></select>
                    <button class="btn btn-success btn-sm" id="btnAsignarEspecialidad">Añadir</button>
                </div>
                <div class="table-responsive">
                    <table id="tbEspecialidadesDoc" class="table table-hover table-sm w-100">
                        <thead>
                            <tr>
                                <th>Especialidad</th>
                                <th style="width:50px"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdCalcom" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Configuración Cal.com: <span id="lblDoctorCal" class="badge bg-info"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-start">
                <div class="row g-2">
                    <div class="col-md-6"><label class="small">API Key</label><input type="text" class="form-control" id="txtCalApiKey"></div>
                    <div class="col-md-6"><label class="small">Cal Username</label><input type="text" class="form-control" id="txtCalUsername"></div>
                    <div class="col-md-6"><label class="small">Event Type Id (Seleccionado)</label><input type="number" class="form-control" id="txtCalEventTypeId" readonly></div>
                    <div class="col-md-6"><label class="small">Cal Public URL</label><input type="text" class="form-control" id="txtCalPublicUrl"></div>
                    <div class="col-md-12"><label class="small">Nombre del Evento</label><input type="text" class="form-control" id="txtCalEventName" readonly></div>
                    <div id="divApiInfo" class="col-12 mt-3 border p-2 bg-light" style="max-height: 250px; overflow-y: auto;">
                        <p class="text-muted small">Pulsa "Consultar API" para cargar los eventos...</p>
                    </div>
                    <div class="col-12 mt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="chkCalIsActive">
                            <label class="form-check-label">Sincronización Activa</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-repro-verde" id="btnConsultarApi">Consultar API</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarCalcom">Guardar Cal</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        (function () {
            "use strict";
            let tablaData;
            let idEditar = 0;
            const controlador = "Doctor";
            const modal = "mdData";

            window.openHelpVideo = function (fileName) {
                const url = "/helps/" + encodeURIComponent(fileName);
                window.open(url, "helpVideo", "width=900,height=520");
            };

            function limpiarModal() {
                idEditar = 0;
                $("#txtNroDocumento, #txtNombres, #txtApellidos, #txtBiografia, #txtResumenValoracion, #txtFoto").val("");
                $("#cboGenero").val("M");
                $("#txtValoracion, #txtValoracionAi").val("3.0");
            }

            function llenarModal(row) {
                limpiarModal();
                idEditar = row.idDoctor ?? row.IdDoctor ?? 0;
                $("#txtNroDocumento").val(row.numeroDocumentoIdentidad ?? row.NumeroDocumentoIdentidad ?? "");
                $("#txtNombres").val(row.nombres ?? row.Nombres ?? "");
                $("#txtApellidos").val(row.apellidos ?? row.Apellidos ?? "");
                $("#cboGenero").val(row.genero ?? row.Genero ?? "M");
                $("#txtBiografia").val(row.biografia ?? row.Biografia ?? "");
                $("#txtValoracion").val(row.valoracion ?? row.Valoracion ?? "3.0");
                $("#txtValoracionAi").val(row.valoracionAi ?? row.ValoracionAi ?? "3.0");
                $("#txtResumenValoracion").val(row.resumenValoracion ?? row.ResumenValoracion ?? "");
                        // Dentro de llenarModal(row)
   
           // Mostramos la foto llamando al nuevo método del controlador
           idEditar = row.idDoctor ?? row.IdDoctor ?? 0;

        if (idEditar > 0) {
            const urlFoto = `/Doctor/VerFoto?id=${idEditar}&t=${new Date().getTime()}`;

            // 1. Muestra la foto automáticamente
            $("#imgFotoPreview").attr("src", urlFoto).show();

            // 2. Configura el botón de descargar
            $("#btnDescargarFoto").attr("href", urlFoto).show();
        } else {
            $("#imgFotoPreview, #btnDescargarFoto").hide();
        }
            }

            async function cargarGeneros() {
                $("#cboGenero").html('<option value="M">M</option><option value="F">F</option>');
            }

            async function cargarEspecialidades() {
                const r = await fetch("/Especialidad/Lista");
                const j = await r.json().catch(() => null);
                const arr = (j && j.data) ? j.data : [];
                const cboMul = document.getElementById("cboEspecialidadMultiple");
                if (cboMul) {
                    cboMul.innerHTML = "<option value=''>-- Seleccionar --</option>";
                    arr.forEach(e => {
                        const o = document.createElement("option");
                        o.value = e.idEspecialidad ?? e.IdEspecialidad;
                        o.textContent = e.nombre ?? e.Nombre;
                        cboMul.appendChild(o);
                    });
                }
            }

            async function guardarDoctor() {
                const formData = new FormData();
                formData.append("IdDoctor", idEditar);
                formData.append("NumeroDocumentoIdentidad", $("#txtNroDocumento").val());
                formData.append("Nombres", $("#txtNombres").val());
                formData.append("Apellidos", $("#txtApellidos").val());
                formData.append("Genero", $("#cboGenero").val());
                formData.append("Biografia", $("#txtBiografia").val());

                // Corrección decimales (reemplazar . por , para C#)
                formData.append("Valoracion", $("#txtValoracion").val().toString().replace('.', ','));
                formData.append("ValoracionAi", $("#txtValoracionAi").val().toString().replace('.', ','));
                formData.append("ResumenValoracion", $("#txtResumenValoracion").val());

                const inputFoto = document.getElementById('txtFoto');
                if (inputFoto && inputFoto.files.length > 0) {
                    formData.append("FotoFile", inputFoto.files[0]);
                }

                const url = `/${controlador}/${idEditar > 0 ? "Editar" : "Guardar"}`;
                const r = await fetch(url, { method: idEditar > 0 ? "PUT" : "POST", body: formData });
                if (r.ok) {
                    Swal.fire("OK", "Doctor guardado con éxito.", "success");
                    bootstrap.Modal.getOrCreateInstance(document.getElementById(modal)).hide();
                    tablaData.ajax.reload(null, false);
                }
            }

            async function cargarCalcom(id) {
                // Reset campos Calcom
                $("#txtCalApiKey, #txtCalUsername, #txtCalEventTypeId, #txtCalPublicUrl, #txtCalEventName").val("");
                $("#chkCalIsActive").prop("checked", false);
                $("#divApiInfo").html('<p class="text-muted small">Pulsa "Consultar API" para cargar los eventos...</p>');

                const r = await fetch(`/Doctor/ObtenerCalcom?idDoctor=${id}`);
                const j = await r.json();
                if (j && j.data) {
                    const d = j.data;
                    $("#txtCalApiKey").val(d.apiKey);
                    $("#txtCalUsername").val(d.calUsername);
                    $("#txtCalEventTypeId").val(d.calEventTypeId);
                    $("#txtCalPublicUrl").val(d.calPublicUrl);
                    $("#txtCalEventName").val(d.calEventName || "");
                    $("#chkCalIsActive").prop("checked", d.isActive !== false);
                    $("#lblDoctorCal").text($("#txtNombres").val());
                }
            }

            async function consultarApiCal() {
                const key = $("#txtCalApiKey").val();
                if (!key) return Swal.fire("Aviso", "Ingresa la API Key", "warning");
                $("#divApiInfo").html('<div class="spinner-border spinner-border-sm" role="status"></div> Buscando...');

                const r = await fetch(`/Doctor/GetDetallesApiCal?apiKey=${encodeURIComponent(key)}`);
                const j = await r.json();

                if (r.ok && j.data && j.data.length > 0) {
                    let html = '<div class="list-group">';
                    j.data.forEach(e => {
                        html += `<a href="#" class="list-group-item list-group-item-action api-item" data-id="${e.id}" data-title="${e.title}" data-slug="${e.slug}">
                                    <strong>${e.title}</strong><br><small>ID: ${e.id} | Slug: ${e.slug}</small>
                                 </a>`;
                    });
                    html += '</div>';
                    $("#divApiInfo").html(html);

                    $(".api-item").on("click", function(e) {
                        e.preventDefault();
                        $(".api-item").removeClass("selected active");
                        $(this).addClass("selected active");
                        $("#txtCalEventTypeId").val($(this).data("id"));
                        $("#txtCalEventName").val($(this).data("title"));
                        $("#chkCalIsActive").prop("checked", true);
                        const user = $("#txtCalUsername").val();
                        if(user) $("#txtCalPublicUrl").val(`https://cal.com/${user}/${$(this).data("slug")}`);
                    });
                } else {
                    $("#divApiInfo").html('<p class="text-danger small">No se encontraron eventos o la clave es inválida.</p>');
                }
            }

            async function guardarCalcom() {
                const payload = {
                    idDoctor: idEditar,
                    apiKey: $("#txtCalApiKey").val(),
                    calUsername: $("#txtCalUsername").val(),
                    calEventTypeId: parseInt($("#txtCalEventTypeId").val()) || 0,
                    calPublicUrl: $("#txtCalPublicUrl").val(),
                    calEventName: $("#txtCalEventName").val(),
                    isActive: $("#chkCalIsActive").is(":checked")
                };
                const r = await fetch("/Doctor/GuardarCalcom", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });
                if (r.ok) {
                    Swal.fire("OK", "Configuración de Cal.com guardada.", "success");
                    bootstrap.Modal.getOrCreateInstance(document.getElementById("mdCalcom")).hide();
                }
            }

            $(document).ready(async function () {
                await cargarGeneros();
                await cargarEspecialidades();

                tablaData = $("#tbData").DataTable({
                    ajax: { url: `/${controlador}/Lista`, dataSrc: "data" },
                    columns: [
                        {
                            data: null,
                            render: function () {
                                return `<div class="acciones-container">
                                    <button class="btn btn-primary btn-circle btn-editar"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-info btn-circle btn-especialidades"><i class="fas fa-graduation-cap"></i></button>
                                    <button class="btn btn-danger btn-circle btn-eliminar"><i class="fas fa-trash-alt"></i></button>
                                </div>`;
                            }
                        },
                        { data: "numeroDocumentoIdentidad" },
                        { data: "nombres" },
                        { data: "apellidos" },
                        { data: "genero" },
                         {
            data: "especialidadesDoc",
            render: function(data, type, row) {
                // Generamos los badges si existen especialidades
                let badges = (data && data.length > 0)
                    ? data.map(e => `<span class="badge bg-secondary me-1">${e.nombreEspecialidad}</span>`).join("")
                    : ''; // Si no hay datos, devolvemos una cadena vacía en lugar de "Sin especialidad"

                // Retornamos el contenedor con los badges y el botón alineado a la izquierda
                return `<div class="d-flex flex-column align-items-start">
                            <div class="mb-1">${badges}</div>
                            <button type="button" class="btn btn-outline-primary btn-sm btn-especialidades"
                                    style="padding: 2px 8px; font-size: 12px;"
                                    title="Gestionar Especialidades">
                                <i class="fas fa-plus-circle me-1"></i> Especialidades
                            </button>
                        </div>`;
            }
        }
                    ],
                    language: { url: "https://cdn.datatables.net/plug-ins/1.11.5/i18n/es-ES.json" }
                });
                        // Previsualización de la foto seleccionada localmente
        $("#txtFoto").on("change", function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    $("#imgFotoPreview").attr("src", e.target.result).show();
                };
                reader.readAsDataURL(file);
            }
        });
                $("#btnGuardar").on("click", guardarDoctor);
                $("#btnNuevo").on("click", () => { limpiarModal(); bootstrap.Modal.getOrCreateInstance(document.getElementById(modal)).show(); });

                $("#tbData tbody").on("click", ".btn-editar", function () {
                    const row = tablaData.row($(this).closest("tr")).data();
                    llenarModal(row);
                    bootstrap.Modal.getOrCreateInstance(document.getElementById(modal)).show();
                });

                $("#btnCalcom").on("click", () => {
                    if (idEditar === 0) return Swal.fire("Aviso", "Primero guarda el doctor", "info");
                    cargarCalcom(idEditar);
                    bootstrap.Modal.getOrCreateInstance(document.getElementById("mdCalcom")).show();
                });

                $("#btnConsultarApi").on("click", consultarApiCal);
                $("#btnGuardarCalcom").on("click", guardarCalcom);
      
        // Evento para abrir el modal de especialidades
        $("#tbData tbody").on("click", ".btn-especialidades", function () {
            const row = tablaData.row($(this).closest("tr")).data();
            idEditar = row.idDoctor ?? row.IdDoctor;

            // CONCATENAMOS NOMBRES Y APELLIDOS AQUÍ
            const nombreCompleto = (row.nombres + " " + row.apellidos).trim();
            $("#lblDoctorEsp").text(nombreCompleto);

            cargarEspecialidadesDoctor(idEditar);
            bootstrap.Modal.getOrCreateInstance(document.getElementById("mdEspecialidades")).show();
        });

                $("#btnAsignarEspecialidad").on("click", async function () {
                    const idEsp = $("#cboEspecialidadMultiple").val();
                    if(!idEsp) return;
                    await fetch(`/Doctor/AsignarEspecialidad?idDoctor=${idEditar}&idEspecialidad=${idEsp}`, { method: "POST" });
                    cargarEspecialidadesDoctor(idEditar);
                    tablaData.ajax.reload(null, false);
                });
            });

            window.cargarEspecialidadesDoctor = async function(id) {
                if ($.fn.DataTable.isDataTable('#tbEspecialidadesDoc')) $('#tbEspecialidadesDoc').DataTable().destroy();
                $('#tbEspecialidadesDoc').DataTable({
                    ajax: { url: `/Doctor/ListarEspecialidadesDoctor?idDoctor=${id}`, dataSrc: "data" },
                    columns: [
                        { data: "nombreEspecialidad" },
                        {
                            data: "idEspecialidadDoctor",
                            render: data => `<button class="btn btn-danger btn-sm" onclick="eliminarEspecialidad(${data})"><i class="fas fa-trash"></i></button>`
                        }
                    ],
                    paging: false, dom: 't'
                });
            };

            window.eliminarEspecialidad = async function(id) {
                const res = await Swal.fire({ title: "¿Quitar?", showCancelButton: true });
                if (res.isConfirmed) {
                    await fetch(`/Doctor/EliminarEspecialidad?id=${id}`, { method: "DELETE" });
                    cargarEspecialidadesDoctor(idEditar);
                    tablaData.ajax.reload(null, false);
                }
            };
        })();
    </script>
}